bsite\"\n              type=\"text\"\n              class=\"form-control\"\n              id=\"myWebSite-web\"\n              name=\"myWebSite\"\n              placeholder=\"网址\"\n            />\n          </div>\n        </div>\n      </div>\n      <div class=\"form-group\">\n        <textarea\n          v-model=\"replyMsg.content\"\n          class=\"form-control\"\n          id=\"message-mobile\"\n          name=\"editordata-web\"\n          rows=\"5\"\n          placeholder=\"留言内容*\"\n        ></textarea>\n      </div>\n      <div class=\"form-group\">\n        <button class=\"btn btn-info\" type=\"button\" @click=\"clickReplyMsg\">\n          <span class=\"glyphicon glyphicon-send\" aria-hidden=\"true\"></span>发送\n        </button>\n        <span id=\"callback-msg-web\"></span>\n      </div>\n      <!-- <div id=\"form-messages\"></div> -->\n    </form>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: \"ReplyMessageBox\",\n  props: {\n    messageReplyInfo: {\n      type: Object,\n    },\n  },\n  data() {\n    return {\n      replyMsg: {\n        userName: null,\n        email: null,\n        webUrl: null,\n        content: null,\n        parentId: this.messageReplyInfo.id,\n        replyId: this.messageReplyInfo.repId,\n        replyName: this.messageReplyInfo.name,\n      },\n      commentId: 0,\n    };\n  },\n  methods: {\n    clickReplyMsg() {\n      //this.replMsg.replyId=messageId;\n      // 调用自定义事件，传入参数\n      this.$emit(\"getReplyMsg\", this.replyMsg);\n    },\n  },\n};\n</script>\n\n<style>\n</style>"],"mappings":"AAiEA;EACAA,IAAA;EACAC,KAAA;IACAC,gBAAA;MACAC,IAAA,EAAAC;IACA;EACA;EACAC,KAAA;IACA;MACAC,QAAA;QACAC,QAAA;QACAC,KAAA;QACAC,MAAA;QACAC,OAAA;QACAC,QAAA,OAAAT,gBAAA,CAAAU,EAAA;QACAC,OAAA,OAAAX,gBAAA,CAAAY,KAAA;QACAC,SAAA,OAAAb,gBAAA,CAAAF;MACA;MACAgB,SAAA;IACA;EACA;EACAC,OAAA;IACAC,cAAA;MACA;MACA;MACA,KAAAC,KAAA,qBAAAb,QAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}