g, {\n          position: \"top-center\",\n          duration: 3000,\n          theme: \"bubble\"\n        });\n      });\n    },\n    getAllArticleCategory() {\n      (0, _geekplus.listSubCategory)().then(response => {\n        this.allCategoryList = response.data;\n      }).catch(error => {\n        this.$toasted.error(error.msg, {\n          position: \"top-center\",\n          duration: 3000,\n          theme: \"bubble\"\n        });\n      });\n    },\n    searchResult() {\n      if (this.keywords !== \"\") {\n        //this.$router.push(\"/search?keayword=\"+this.keywords);\n        this.$router.push({\n          path: \"/search\",\n          query: {\n            keyword: this.keywords\n          }\n        });\n      }\n      this.keywords = \"\";\n    }\n  }\n};\nexports.default = _default;","map":{"version":3,"names":["_geekplus","require","_default","data","keywords","articleInfo","articleCategory","articleContent","articleTitle","authorId","authorName","createBy","createTime","id","isDisplay","likeCount","params","remark","searchValue","updateBy","updateTime","viewCount","sixNewArticle","allCategoryList","created","getArticle","getSixNewArticle","getAllArticleCategory","mounted","methods","$route","articleId","param","getArticleDetail","then","response","window","document","title","catch","error","$toasted","msg","position","duration","theme","getSixNewestArticle","listSubCategory","searchResult","$router","push","path","query","keyword","exports","default"],"sources":["src/views/article/ArticleContent.vue"],"sourcesContent":["<template>\n  <div class=\"container\">\n    <section class=\"container-content\">\n      <div class=\"row\">\n        <div class=\"col-lg-9 col-md-9 col-sm-9 col-xs-12\">\n          <div class=\"article-content\">\n            <h3>\n              {{\n                articleInfo.articleTitle\n                  ? articleInfo.articleTitle\n                  : \"代码没有双全法，人生也一样\"\n              }}\n            </h3>\n            <!-- <h4>param传值{{ $route.params.articleId }}</h4> -->\n            <div class=\"tt\">\n              <label\n                >作者：{{\n                  articleInfo.authorName ? articleInfo.authorName : \"周舟\"\n                }}</label\n              >\n              |\n              <label\n                >发布：{{\n                  articleInfo.createTime ? articleInfo.createTime : \"2019.05.31\"\n                }}</label\n              >\n              |\n              <label\n                >浏览：{{\n                  articleInfo.viewCount ? articleInfo.viewCount : 38909\n                }}</label\n              >\n            </div>\n            <div\n              class=\"content\"\n              v-if=\"articleInfo.articleContent\"\n              v-html=\"articleInfo.articleContent\"\n            ></div>\n            <div class=\"content\" v-else>\n              <p>\n                软件设计要考虑诸多方面，权衡各种利弊，以设计一个趋于完美的解决方案。在方案未落实之前，这也是争论的焦点，探讨的是方案的可行性，然而无论再好的方案都有弊端的，只是众多方案中选优罢了，这点正是本文的主题。程序设计不可能集所有优点于一身，必有牺牲的一面，常常因为为了满足准确性，而牺牲了性能，为了满足某些需求，而冗余了代码，甚至入侵了业务也不惜，因此代码是没有双全法的，有得必有失，不必苛求。\n              </p>\n              <p>\n                代码尚且如此，人生又何尝不是？人生是不完美的，也无法做到十全十美，这不是付出多少的问题，这就是一个真命题，就像地球引力一般的存在，再成功的人也有他遗憾的问题，是因为他厚此薄彼的结果，当然厚此薄彼要加上引号，其动机没有不纯，这就是2选1的问题，举个不恰当的例子，一个男人有了外遇，被老婆知道了，老婆和情人其实都有一个共同的诉求，就是男人必须在两者之间选择一个，这时男人不管如何做出选择都是痛的，如若男人继续做出中庸的选择，那么两头都不讨好，最后只能竹篮打水一场空，两个人都得不到，举这个例子可能不太恰当，但能说明问题所在。\n              </p>\n              <p>\n                说了这么多，无非就是论证并无双全法之说，唯一的办法是以自己的诉求为出发点，偏向和放大一方，以最小的代价舍弃另一方。以上纯属个人无稽之谈，愉悦而已，喜则取之，厌则弃之。\n              </p>\n            </div>\n          </div>\n          <div class=\"row\">\n            <div class=\"col-lg-12 col-md-12 col-sm-12 col-xs-12\">\n              <h6>评论:</h6>\n              <div class=\"comments_input_area\">\n                <div class=\"row\">\n                  <div class=\"col-lg-4 col--md-4 col-sm-4\">\n                    <div class=\"form-group\">\n                      <input\n                        type=\"text\"\n 