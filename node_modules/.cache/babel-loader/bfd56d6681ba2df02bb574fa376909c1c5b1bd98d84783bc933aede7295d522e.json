-msg-mobile\"></span>\n            <button type=\"button\" class=\"btn btn-default\" data-dismiss=\"modal\">\n              关闭\n            </button>\n            <button\n              type=\"button\"\n              class=\"btn btn-primary\"\n              onclick=\"mobileLeaveWords()\"\n            >\n              提交\n            </button>\n          </div>\n        </div>\n        <!-- /.modal-content -->\n      </div>\n      <!-- /.modal -->\n    </div>\n  </div>\n</template>\n\n<script>\nimport GCLogo from \"@/assets/logo.png\";\nimport MKLogo from \"@/assets/icon/mai.png\";\n//递归显示留言的组件\nimport SubReplyMessage from \"@/components/comment/SubReplyMessage.vue\"\n//调用回复消息的组件\nimport ReplyMessageBox from \"@/components/comment/ReplyMessageBox.vue\"\nimport {sendUserComment,getAllUserComment,getUserCommentCount,getLatestUserComment} from \"@/api/geekplus/geekplus\"\n\nexport default {\n    components:{\n        SubReplyMessage,\n        ReplyMessageBox\n    },\n    data(){\n        return {\n            GPLogo: GCLogo,\n            UserLogo: MKLogo,\n            isDisplayMsgBox: false,\n            replyBoxIndex:-1,\n            //网站直接留言\n            userMessage:{},\n            leaveMessage:[{\n                id:'1',\n                name:\"普通用户\",\n                email:'',\n                website:'',\n                content:'你好',\n                createTime:'2023-03-03',\n                replyUserComment:[{\n                    id:'11',\n                    name:\"geekplus\",\n                    email:'',\n                    website:'',\n                    content:'嗯！你好！',\n                    createTime:'2023-03-11',\n                    replyUserComment:[{\n                        id:'111',\n                        name:\"普通用户\",\n                        email:'',\n                        website:'',\n                        content:'你是做什么的，你为什么要建这个网站？',\n                        createTime:'2023-03-13',\n                    }]\n                },{\n    