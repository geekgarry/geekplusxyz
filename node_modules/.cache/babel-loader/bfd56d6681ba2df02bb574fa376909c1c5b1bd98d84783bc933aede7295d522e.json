{"ast":null,"code":"import GCLogo from \"@/assets/logo.png\";\nimport MKLogo from \"@/assets/icon/mai.png\";\n//递归显示留言的组件\nimport SubReplyMessage from \"@/components/comment/SubReplyMessage.vue\";\n//调用回复消息的组件\nimport ReplyMessageBox from \"@/components/comment/ReplyMessageBox.vue\";\nimport { sendUserComment, getAllUserComment, getUserCommentCount, getLatestUserComment } from \"@/api/geekplus/geekplus\";\nexport default {\n  components: {\n    SubReplyMessage,\n    ReplyMessageBox\n  },\n  data() {\n    return {\n      GPLogo: GCLogo,\n      UserLogo: MKLogo,\n      isDisplayMsgBox: false,\n      replyBoxIndex: -1,\n      //网站直接留言\n      userMessage: {},\n      leaveMessage: [{\n        id: '1',\n        name: \"普通用户\",\n        email: '',\n        website: '',\n        content: '你好',\n        createTime: '2023-03-03',\n        replyUserComment: [{\n          id: '11',\n          name: \"geekplus\",\n          email: '',\n          website: '',\n          content: '嗯！你好！',\n          createTime: '2023-03-11',\n          replyUserComment: [{\n            id: '111',\n            name: \"普通用户\",\n            email: '',\n            website: '',\n            content: '你是做什么的，你为什么要建这个网站？',\n            createTime: '2023-03-13'\n          }]\n        }, {\n          id: '12',\n          name: \"geekplus\",\n          email: '',\n          website: '',\n          content: 'what？你在说什么？我不知道！',\n          createTime: '2023-03-09',\n          replyUserComment: [{\n            id: '121',\n            name: \"普通用户\",\n            email: '',\n            website: '',\n            content: '我是一个孤独的人，一个没有朋友的人？',\n            createTime: '2023-03-17'\n          }]\n        }]\n      }]\n    };\n  },\n  created() {\n    this.getAllUserCommentMsg();\n  },\n  mounted() {\n    // ref绑定自定义事件\n    //this.$refs.replyMsgRef.$on('getReplyMsg',this.getReplyMessage);\n  },\n  methods: {\n    getAllUserCommentMsg() {\n      let data = {};\n      getAllUserComment(data).then(response => {\n        console.log(response);\n        this.leaveMessage = response.rows;\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n    userLeaveMessage() {\n      //this.userMessage.dateTime=this.getNowDate()\n      //this.leaveMessage.push(this.userMessage);\n      sendUserComment(this.userMessage).then(response => {\n        console.log(response);\n        this.closeReplyBox();\n        this.getAllUserCommentMsg();\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n    getReplyMessage(data) {\n      let replyMsg = {\n        name: data.name,\n        email: data.email,\n        website: data.website,\n        content: data.content\n        //dateTime: this.getNowDate(),\n        //replyUserComment:[]\n      };\n      //this.isDisplayMsgBox=false;\n      //this.leaveMessage.filter(item => item.id===this.replyBoxIndex)[0].replyUserComment.push(replyMsg);\n      //console.log(this.leaveMessage.filter(item => item.id===this.replyBoxIndex))\n      //console.log(data)\n      sendUserComment(data).then(response => {\n        console.log(response);\n        this.closeReplyBox();\n        this.getAllUserCommentMsg();\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n    getUserCommentStatus(data) {\n      if (data === \"1\") {\n        this.closeReplyBox();\n        this.getAllUserCommentMsg();\n      }\n    },\n    openReplyBox(index) {\n      //this.isDisplayMsgBox=true;\n      this.replyBoxIndex = index;\n      console.log(this.replyBoxIndex);\n    },\n    closeReplyBox() {\n      //this.isDisplayMsgBox=false;\n      this.replyBoxIndex = -1;\n    }\n  }\n};","map":{"version":3,"names":["GCLogo","MKLogo","SubReplyMessage","ReplyMessageBox","sendUserComment","getAllUserComment","getUserCommentCount","getLatestUserComment","components","data","GPLogo","UserLogo","isDisplayMsgBox","replyBoxIndex","userMessage","leaveMessage","id","name","email","website","content","createTime","replyUserComment","created","getAllUserCommentMsg","mounted","methods","then","response","console","log","rows","catch","error","userLeaveMessage","closeReplyBox","getReplyMessage","replyMsg","getUserCommentStatus","openReplyBox","index"],"sources":["src/views/contact/LeaveMessage.vue"],"sourcesContent":["<template>\n  <div class=\"container container-content\">\n    <section class=\"row\">\n      <div class=\"col-lg-9 col-md-9 col-sm-12 col-xs-12 animate__animated animate__slideInLeft\">\n        <div class=\"hidden-xs\" id=\"pblish-comment\">\n          <div class=\"container-fluid\">\n            <div class=\"row\">\n              <div class=\"contact-box\">\n                <form id=\"ajax-contact-web\" action=\"\" method=\"post\">\n                    <div class=\"form-group row\">\n                      <div class=\"col-lg-4 col-md-4 col-sm-4\">\n                        <input type=\"hidden\" value=\"0\" name=\"parentId\" />\n                        <input\n                          v-model=\"userMessage.name\"\n                          type=\"text\"\n                          class=\"form-control\"\n                          id=\"name-web\"\n                          name=\"name\"\n                          placeholder=\"姓名*\"\n                          required=\"\"\n                        />\n                      </div>\n                      <div class=\"col-lg-4 col-md-4 col-sm-4\">\n                        <input\n                          v-model=\"userMessage.email\"\n                          type=\"email\"\n                          class=\"form-control\"\n                          id=\"email-web\"\n                          name=\"email\"\n                          placeholder=\"Email*\"\n                          required=\"\"\n                        />\n                      </div>\n                      <div class=\"col-lg-4 col-md-4 col-sm-4\">\n                        <input\n                          v-model=\"userMessage.website\"\n                          type=\"text\"\n                          class=\"form-control\"\n                          id=\"myWebSite-web\"\n                          name=\"myWebSite\"\n                          placeholder=\"网址\"\n                        />\n                      </div>\n                    </div>\n                    <div class=\"form-group\">\n                      <textarea\n                          v-model=\"userMessage.content\"\n                          class=\"form-control\"\n                          id=\"message-mobile\"\n                          name=\"editordata-web\"\n                          rows=\"5\"\n                          placeholder=\"留言内容*\"\n                      ></textarea>\n                    </div>\n                    <div class=\"form-group\">\n                      <button\n                        class=\"btn btn-primary\"\n                        type=\"button\"\n                        @click=\"userLeaveMessage\"\n                      >发送</button>\n                      <span id=\"callback-msg-web\"></span>\n                    </div>\n                    <!-- <div id=\"form-messages\"></div> -->\n                  </form>\n              </div>\n            </div>\n          </div>\n        </div>\n        <div class=\"container-fluid\">\n          <div class=\"row\">\n            <div class=\"well well-sm well-no-margin\">\n              <h5 id=\"lw-number\">留言条数:</h5>\n            </div>\n          </div>\n        </div>\n        <div class=\"leavewords-container\">\n          <div class=\"articleComment\">\n            <div class=\"comment-lw\" v-for=\"(item,index) in leaveMessage\" :key=\"index\">\n              <div class=\"comment-main\">\n                <a class=\"user-logo\"><img :src=\"UserLogo\" /></a>\n                <div class=\"comment-content\">\n                  <div class=\"comment-info\">\n                    <a>{{item.name}}</a><span>{{item.createTime}}</span>\n                  </div>\n                  <div class=\"comment-text\">\n                    {{ item.content }}\n                  </div>\n                  <div class=\"comment-action\">\n                    <a href=\"javascript:void(0)\" @click=\"openReplyBox(item.id)\">回复</a>\n                    &nbsp;\n                    <a v-if=\"item.id===replyBoxIndex\" href=\"javascript:void(0)\" @click=\"closeReplyBox\">关闭</a>\n                  </div>\n                  <!-- <div v-if=\"isDisplayMsgBox\"> -->\n                    <reply-message-box :messageId=\"item.id\" v-if=\"item.id===replyBoxIndex\" v-on:getReplyMsg=\"getReplyMessage\" ref=\"replyMsgRef\"></reply-message-box>\n                  <!-- </div> -->\n                </div>\n              </div>\n              <div v-if=\"item.replyUserComment\" class=\"sub-comment-lw\" >\n                <sub-reply-message  v-on:sendUserCommentStatus=\"getUserCommentStatus\" :replyMessage=\"item.replyUserComment\"></sub-reply-message>\n              </div>\n            </div>\n          </div>\n          <br />\n        </div>\n        <div class=\"pagenumber\">\n          <div class=\"container-fluid\">\n            <div class=\"row\">\n              <nav class=\"pagenum\" id=\"pagenum1\">\n                <span class=\"pagenum-btns\">\n                  <a class=\"pagenum-prev\">&laquo;</a>\n                  <a class=\"pagenum-num\">1</a>\n                  <span class=\"pagenum-break\">...</span>\n                  <a class=\"pagenum-num\">7</a>\n                  <a class=\"pagenum-num\">8</a>\n                  <a class=\"pagenum-active\">9</a>\n                  <a class=\"pagenum-num\">10</a>\n                  <a class=\"pagenum-num\">11</a>\n                  <span class=\"pagenum-break\">...</span>\n                  <a class=\"pagenum-num\">98</a>\n                  <a class=\"pagenum-next\">&raquo;</a>\n                </span>\n                <span class=\"pagenum-skip\">\n                  共<b class=\"pagenum-total\">98</b>页&nbsp;&nbsp;到第<input\n                    class=\"pagenum-input\"\n                    value=\"1\"\n                    type=\"text\"\n                  />页<a class=\"pagenum-ok\">确定</a>\n                </span>\n              </nav>\n            </div>\n          </div>\n        </div>\n      </div>\n      <aside class=\"col-lg-3 col-md-3 col-sm-12 col-xs-12 right animated slideInRight\">\n        <div class=\"right-fun\">\n          <!-- <div class=\"alert alert-info alert-dismissible fade in\">\n            <a href=\"#\" class=\"close\" data-dismiss=\"alert\">&times;</a>\n            博主自建并正在使用的书单已经放到\n            <a\n              title=\"\"\n              href=\"https://mubu.com/doc/dlGWUevFA\"\n              target=\"_blank\"\n              data-original-title=\"个人书单\"\n              class=\"alert-link\"\n            >\n              幕布</a\n            >了，感兴趣的书友可以参考一下。另外，顺便安利一下\n            <a\n              title=\"\"\n              href=\"https://mubu.com/inv/44164\"\n              target=\"_blank\"\n              data-original-title=\"注册地址\"\n              class=\"alert-link\"\n              >幕布 </a\n            >这个工具，它可以用来整理思维大纲，自动生成好看的思维导图，你值得拥有！\n          </div> -->\n          <div class=\"model hidden-xs\">\n            <div class=\"title\">问题搜索</div>\n            <div class=\"content\">\n              <div class=\"searche_bar7\">\n                <form>\n                  <!-- <span class=\"glyphicon glyphicon-search pull-left\"></span> -->\n                  <input\n                    type=\"text\"\n                    placeholder=\"请输入关键词\"\n                    name=\"keywords\"\n                  />\n                  <button type=\"submit\"></button>\n                </form>\n              </div>\n            </div>\n          </div>\n          <div\n            id=\"my-social\"\n            class=\"panel panel-info hidden-xs\"\n            style=\"margin-top: 20px\"\n          >\n            <div class=\"panel-heading\">\n              <span class=\"glyphicon glyphicon-hand-right\"></span\n              >&nbsp;我的社交\n            </div>\n            <div class=\"\">\n              <div class=\"my-social-list\">\n                <a\n                  id=\"S_ins\"\n                  title=\"Instagram\"\n                  target=\"_blank\"\n                  href=\"https://www.instagram.com/geekcjj/\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"Instagram\"\n                >\n                  <i class=\"fa fa-instagram\" aria-hidden=\"true\"></i>\n                </a>\n                <a\n                  id=\"s_douban\"\n                  title=\"新浪微博\"\n                  target=\"_blank\"\n                  href=\"https://www.weibo.com/u/5373856458\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"新浪微博\"\n                >\n                  <i class=\"fa fa-weibo\"></i>\n                </a>\n                <a\n                  id=\"s_douban\"\n                  title=\"豆瓣\"\n                  target=\"_blank\"\n                  href=\"https://www.douban.com/people/geekcjj/\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"豆瓣\"\n                >\n                  <i class=\"fa fa-dashcube\"></i>\n                </a>\n                <a\n                  id=\"s_qq_music\"\n                  title=\"qq音乐\"\n                  target=\"_blank\"\n                  href=\"https://y.qq.com/portal/profile.html?uin=oKSFNKC57KvA7c**\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"qq音乐\"\n                >\n                  <i class=\"fa fa-music\"></i>\n                </a>\n                <a\n                  id=\"s_email\"\n                  title=\"邮箱\"\n                  target=\"_blank\"\n                  href=\"mailto:geekcjj@gmail.com\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"EMAIL\"\n                >\n                  <i class=\"fa fa-envelope-o\"></i>\n                </a>\n                <a\n                  id=\"s_github\"\n                  title=\"GitHub\"\n                  target=\"_blank\"\n                  href=\"https://github.com/geekcjj\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"GITHUB\"\n                >\n                  <i class=\"fa fa-github\"></i>\n                </a>\n                <a\n                  id=\"s_gitee\"\n                  title=\"Gitee码云\"\n                  target=\"_blank\"\n                  href=\"https://gitee.com/geekcjj\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"码云\"\n                >\n                  <i class=\"fa fa-git\"></i>\n                </a>\n                <a\n                  id=\"s_rss\"\n                  title=\"RSS订阅\"\n                  target=\"_blank\"\n                  href=\"http://www.zifangsky.cn/feed/\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"RSS\"\n                >\n                  <i class=\"fa fa-rss-square\"></i>\n                </a>\n              </div>\n            </div>\n          </div>\n          <!-- <div\n            id=\"geekcjj-tool\"\n            class=\"panel panel-info hidden-xs\"\n            style=\"margin-top: 20px\"\n          >\n            <div class=\"panel-heading\">\n              <span class=\"glyphicon glyphicon-hand-right\"></span\n              >&nbsp;我是GEEKCJJ\n            </div>\n            <div class=\"\">\n              <div class=\"my-blog-tool\">\n                <a\n                  id=\"S_ins\"\n                  title=\"Instagram\"\n                  target=\"_blank\"\n                  href=\"https://www.instagram.com/geekcjj/\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"Instagram\"\n                >\n                  <i class=\"fa fa-instagram fa-lg\" aria-hidden=\"true\"></i>\n                </a>\n                <a\n                  id=\"s_douban\"\n                  title=\"新浪微博\"\n                  target=\"_blank\"\n                  href=\"https://www.weibo.com/u/5373856458\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"新浪微博\"\n                >\n                  <i class=\"fa fa-weibo fa-lg\"></i>\n                </a>\n                <a\n                  id=\"s_douban\"\n                  title=\"豆瓣\"\n                  target=\"_blank\"\n                  href=\"https://www.douban.com/people/geekcjj/\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"豆瓣\"\n                >\n                  <i class=\"fa fa-dashcube fa-lg\"></i>\n                </a>\n                <a\n                  id=\"s_qq_music\"\n                  title=\"qq音乐\"\n                  target=\"_blank\"\n                  href=\"https://y.qq.com/portal/profile.html?uin=oKSFNKC57KvA7c**\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"qq音乐\"\n                >\n                  <i class=\"fa fa-music fa-lg\"></i>\n                </a>\n                <a\n                  id=\"s_email\"\n                  title=\"邮箱\"\n                  target=\"_blank\"\n                  href=\"mailto:geekcjj@gmail.com\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"EMAIL\"\n                >\n                  <i class=\"fa fa-envelope-o fa-lg\"></i>\n                </a>\n                <a\n                  id=\"s_github\"\n                  title=\"GitHub\"\n                  target=\"_blank\"\n                  href=\"https://github.com/geekcjj\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"GITHUB\"\n                >\n                  <i class=\"fa fa-github fa-lg\"></i>\n                </a>\n                <a\n                  id=\"s_gitee\"\n                  title=\"Gitee码云\"\n                  target=\"_blank\"\n                  href=\"https://gitee.com/geekcjj\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"码云\"\n                >\n                  <i class=\"fa fa-git fa-lg\"></i>\n                </a>\n                <a\n                  id=\"s_rss\"\n                  title=\"RSS订阅\"\n                  target=\"_blank\"\n                  href=\"http://www.zifangsky.cn/feed/\"\n                  data-toggle=\"tooltip\"\n                  data-placement=\"bottom\"\n                  data-original-title=\"RSS\"\n                >\n                  <i class=\"fa fa-rss-square fa-lg\"></i>\n                </a>\n              </div>\n            </div>\n          </div> -->\n          <div class=\"panel panel-default\" style=\"margin-top: 20px\">\n            <div\n              class=\"panel-heading\"\n              style=\"background: rgba(0, 0, 0, 0.0001)\"\n            >\n              <span class=\"glyphicon glyphicon-th\"></span>&nbsp;分类\n            </div>\n            <div class=\"panel-body\" id=\"cat-list\">\n              <a style=\"margin-bottom: 3px\" class=\"btn btn-default btn-sm\"\n                >Linux系统编程<span class=\"badge badge-info\"></span>\n              </a>\n              <a style=\"margin-bottom: 3px\" class=\"btn btn-default btn-sm\"\n                >Python<span class=\"badge badge-info\"></span>\n              </a>\n              <a style=\"margin-bottom: 3px\" class=\"btn btn-default btn-sm\"\n                >Django<span class=\"badge badge-info\"></span>\n              </a>\n              <a style=\"margin-bottom: 3px\" class=\"btn btn-default btn-sm\"\n                >深度学习<span class=\"badge badge-info\"></span>\n              </a>\n              <a style=\"margin-bottom: 3px\" class=\"btn btn-default btn-sm\"\n                >MySql<span class=\"badge badge-info\"></span>\n              </a>\n              <a style=\"margin-bottom: 3px\" class=\"btn btn-default btn-sm\"\n                >生活<span class=\"badge badge-info\"></span>\n                <!-- type=\"button\" -->\n              </a>\n            </div>\n          </div>\n          <div class=\"panel panel-default\" style=\"margin-top: 20px\">\n            <div\n              class=\"panel-heading\"\n              style=\"background: rgba(0, 0, 0, 0.0001)\"\n            >\n              <span class=\"glyphicon glyphicon-th-list\"></span\n              >&nbsp;热门文章\n            </div>\n            <div class=\"panel-body recommendlist\">\n              <!-- <div class=\"model recommend\">\n                                                                              <div class=\"title\">热门推荐</div>\n                                                                              <div class=\"content\"> -->\n              <p>\n                <a href=\"http://www.youtiy.com/detail_317.html\"\n                  >dw个人网页模板作业成品</a\n                >\n              </p>\n              <p>\n                <a href=\"http://www.youtiy.com/detail_382.html\"\n                  >HTML个人简历源代码</a\n                >\n              </p>\n              <p>\n                <a href=\"http://www.youtiy.com/detail_381.html\"\n                  >自我介绍个人网页设计模板</a\n                >\n              </p>\n              <p>\n                <a href=\"http://www.youtiy.com/detail_379.html\"\n                  >DIV+CSS静态HTML网页设计模板</a\n                >\n              </p>\n              <p>\n                <a href=\"http://www.youtiy.com/detail_377.html\"\n                  >一个完整的html网页设计代码免费下载</a\n                >\n              </p>\n            </div>\n          </div>\n        </div>\n      </aside>\n    </section>\n    <!-- 按钮触发模态框 -->\n    <button\n      class=\"btn btn-primary visible-xs\"\n      style=\"position:fixed;right: 9px;bottom: 100px;background-color: #ccc;z-index: 99;\"\n      data-toggle=\"modal\"\n      data-target=\"#leaveMessageModal\"\n    >\n      <span class=\"glyphicon glyphicon-edit\"></span>&nbsp;留言评论\n    </button>\n    <!-- 模态框（Modal） -->\n    <div\n      class=\"modal fade\"\n      id=\"leaveMessageModal\"\n      tabindex=\"-1\"\n      role=\"dialog\"\n      aria-labelledby=\"myModalLabel\"\n      aria-hidden=\"true\"\n    >\n      <div class=\"modal-dialog\">\n        <div class=\"modal-content\">\n          <div class=\"modal-header\">\n            <button\n              type=\"button\"\n              class=\"close\"\n              data-dismiss=\"modal\"\n              aria-hidden=\"true\"\n            >\n              &times;\n            </button>\n            <h4 class=\"modal-title\" id=\"myModalLabel\">留言评论</h4>\n          </div>\n          <div class=\"modal-body\">\n            <section id=\"contact-area\">\n              <div class=\"container-fluid\">\n                <div class=\"row\">\n                  <div class=\"col-lg-10 offset-lg-1\">\n                    <div class=\"contact-box text-center\">\n                      <form id=\"ajax-content-mobile\" action=\"\" method=\"post\">\n                        <div class=\"form-group row\">\n                          <div class=\"col-lg-6 col-md-6 col-sm-6 col-xs-6\">\n                            <input type=\"hidden\" value=\"0\" name=\"parentId\" />\n                            <input\n                              type=\"text\"\n  