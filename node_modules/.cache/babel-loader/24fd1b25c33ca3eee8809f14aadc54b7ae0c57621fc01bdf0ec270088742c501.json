{"ast":null,"code":"import GCLogo from \"@/assets/logo.png\";\nimport MKLogo from \"@/assets/icon/mai.png\";\n//调用回复消息的组件\nimport ReplyMessageBox from \"@/components/comment/ReplyMessageBox.vue\";\nexport default {\n  name: \"SubReplyMessage\",\n  //props: ['replyMessage'],\n  components: {\n    ReplyMessageBox\n  },\n  props: {\n    replyMessage: {\n      type: [Array, Object]\n    }\n  },\n  data: () => {\n    return {\n      GPLogo: GCLogo,\n      UserLogo: MKLogo,\n      isDisplayMsgBox: false,\n      replyBoxIndex: -1\n    };\n  },\n  created() {\n    //console.log(this.replyMessage);\n  },\n  methods: {\n    getReplyMessage(data) {\n      console.log(data);\n      //replyMessage.push(data);\n    },\n\n    openReplyBox(index) {\n      //this.isDisplayMsgBox = true;\n      this.replyBoxIndex = index;\n      console.log(this.replyBoxIndex);\n    },\n    closeReplyBox() {\n      //this.isDisplayMsgBox = false;\n      this.replyBoxIndex = -1;\n    }\n  }\n};","map":{"version":3,"names":["GCLogo","MKLogo","ReplyMessageBox","name","components","props","replyMessage","type","Array","Object","data","GPLogo","UserLogo","isDisplayMsgBox","replyBoxIndex","created","methods","getReplyMessage","console","log","openReplyBox","index","closeReplyBox"],"sources":["src/components/comment/SubReplyMessage.vue"],"sourcesContent":["<template>\n  <!-- 封装的一个递归显示留言和子留言 -->\n  <div>\n    <div\n      class=\"comment-lw\"\n      v-for=\"(subitem, index) in replyMessage\"\n      :key=\"index\"\n    >\n      <div class=\"comment-main\">\n        <a class=\"user-logo\"><img :src=\"UserLogo\" /></a>\n        <div class=\"comment-content\">\n          <div class=\"comment-info\">\n            <a>{{ subitem.name }}</a\n            ><span>{{ subitem.createTime }}</span>\n          </div>\n          <div class=\"comment-text\">\n            {{ subitem.content }}\n          </div>\n          <div class=\"comment-action\">\n            <!-- <a href=\"javascript:void(0)\" selfid=\"6\">回复</a> -->\n            <a href=\"javascript:void(0)\" @click=\"openReplyBox(subitem.id)\">回复</a>\n            &nbsp;\n            <a\n              v-if=\"replyBoxIndex===subitem.id\"\n              href=\"javascript:void(0)\"\n              @click=\"closeReplyBox\"\n              >关闭</a\n            >\n          </div>\n          <reply-message-box\n            v-if=\"replyBoxIndex===subitem.id\" \n            v-on:getReplyMsg=\"getReplyMessage\"\n            :messageId=\"subitem.id\"\n            ref=\"replyMsgRef\"\n          ></reply-message-box>\n        </div>\n      </div>\n      <div v-if=\"subitem.replyMessage\" class=\"sub-comment-lw\">\n        <sub-reply-message\n          :replyMessage=\"subitem.replyMessage\"\n        ></sub-reply-message>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport GCLogo from \"@/assets/logo.png\";\nimport MKLogo from \"@/assets/icon/mai.png\";\n//调用回复消息的组件\nimport ReplyMessageBox from \"@/components/comment/ReplyMessageBox.vue\";\n\nexport default {\n  name: \"SubReplyMessage\",\n  //props: ['replyMessage'],\n  components: {\n    ReplyMessageBox,\n  },\n  props: {\n    replyMessage: {\n      type: [Array, Object],\n    },\n  },\n  data: () => {\n    return {\n      GPLogo: GCLogo,\n      UserLogo: MKLogo,\n      isDisplayMsgBox:false,\n      replyBoxIndex:-1,\n    };\n  },\n  created() {\n    //console.log(this.replyMessage);\n  },\n  methods: {\n    getReplyMessage(data){\n      console.log(data)\n      //replyMessage.push(data);\n    },\n    openReplyBox(index) {\n      //this.isDisplayMsgBox = true;\n      this.replyBoxIndex=index;\n      console.log(this.replyBoxIndex)\n    },\n    closeReplyBox() {\n      //this.isDisplayMsgBox = false;\n      this.replyBoxIndex=-1;\n    },\n  },\n};\n</script>\n\n<style>\n</style>"],"mappings":"AA+CA,OAAAA,MAAA;AACA,OAAAC,MAAA;AACA;AACA,OAAAC,eAAA;AAEA;EACAC,IAAA;EACA;EACAC,UAAA;IACAF;EACA;EACAG,KAAA;IACAC,YAAA;MACAC,IAAA,GAAAC,KAAA,EAAAC,MAAA;IACA;EACA;EACAC,IAAA,EAAAA,CAAA;IACA;MACAC,MAAA,EAAAX,MAAA;MACAY,QAAA,EAAAX,MAAA;MACAY,eAAA;MACAC,aAAA;IACA;EACA;EACAC,QAAA;IACA;EAAA,CACA;EACAC,OAAA;IACAC,gBAAAP,IAAA;MACAQ,OAAA,CAAAC,GAAA,CAAAT,IAAA;MACA;IACA;;IACAU,aAAAC,KAAA;MACA;MACA,KAAAP,aAAA,GAAAO,KAAA;MACAH,OAAA,CAAAC,GAAA,MAAAL,aAAA;IACA;IACAQ,cAAA;MACA;MACA,KAAAR,aAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}