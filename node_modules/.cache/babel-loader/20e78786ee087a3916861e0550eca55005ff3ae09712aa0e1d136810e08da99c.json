{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport MKLogo from \"@/assets/icon/mai.png\";\nimport { getGpArticlesByCategory, getSixNewestArticle, listSubCategory } from \"@/api/geekplus/geekplus\";\nexport default {\n  name: \"ArticleListPage\",\n  data() {\n    return {\n      userName: \"\",\n      keywords: \"\",\n      queryParams: {\n        pageNum: 1,\n        pageSize: 10,\n        pathName: \"\"\n      },\n      articleList: [],\n      articleTotal: 0,\n      pageNum: 9,\n      sixNewArticle: [],\n      allCategoryList: []\n    };\n  },\n  created() {\n    this.$router.onReady(() => {\n      //console.log(this.$route.path);\n      this.queryParams.pathName = this.$route.params.categoryPath;\n    });\n    // console.log(this.$route.params.categoryPath);\n    // console.log(this.queryParams.pathName);\n    this.getArticleList(1);\n    this.getSixNewArticle();\n    this.getAllArticleCategory();\n  },\n  mounted() {\n    //console.log(\"mounted\")\n  },\n  methods: {\n    //分页测试\n    getCurrentNumber(number) {\n      this.pageNum = number;\n    },\n    getArticleList(pageNum) {\n      var total = this.articleTotal;\n      var pageSize = this.queryParams.pageSize;\n      var pageAllNum = total / pageSize;\n      if (pageNum == 0) {\n        this.queryParams.pageNum = 1;\n      } else if (pageNum) {\n        this.queryParams.pageNum = pageNum;\n      } else if (pageNum > Math.ceil(total / pageSize)) {\n        this.queryParams.pageNum = Math.ceil(total / pageSize);\n      }\n      //this.queryParams.pageSize=10;\n      getGpArticlesByCategory(this.queryParams).then(response => {\n        console.log(response);\n        this.articleList = response.rows;\n        this.articleTotal = response.total;\n      }).catch(error => {\n        this.$toasted.error(error.msg, {\n          position: \"top-center\",\n          duration: 3000,\n          theme: \"bubble\"\n        });\n      });\n    },\n    getSixNewArticle() {\n      let data = {\n        isDisplay: 1\n      };\n      getSixNewestArticle(data).then(response => {\n        //console.log(response.data);\n        this.sixNewArticle = response.data;\n      }).catch(error => {\n        //console.log(error.msg)\n        this.$toasted.error(error.msg, {\n          position: \"top-center\",\n          duration: 3000,\n          theme: \"bubble\"\n        });\n      });\n    },\n    getAllArticleCategory() {\n      listSubCategory().then(response => {\n        this.allCategoryList = response.data;\n      }).catch(error => {\n        this.$toasted.error(error.msg, {\n          position: \"top-center\",\n          duration: 3000,\n          theme: \"bubble\"\n        });\n      });\n    },\n    searchResult() {\n      if (this.keywords !== \"\") {\n        //this.$router.push(\"/search?keayword=\"+this.keywords);\n        this.$router.push({\n          path: \"/search\",\n          query: {\n            keyword: this.keywords\n          }\n        });\n      }\n      this.keywords = \"\";\n    }\n  }\n};","map":{"version":3,"names":["MKLogo","getGpArticlesByCategory","getSixNewestArticle","listSubCategory","name","data","userName","keywords","queryParams","pageNum","pageSize","pathName","articleList","articleTotal","sixNewArticle","allCategoryList","created","$router","onReady","$route","params","categoryPath","getArticleList","getSixNewArticle","getAllArticleCategory","mounted","methods","getCurrentNumber","number","total","pageAllNum","Math","ceil","then","response","console","log","rows","catch","error","$toasted","msg","position","duration","theme","isDisplay","searchResult","push","path","query","keyword"],"sources":["src/views/categorypage/ArticleListPage.vue"],"sourcesContent":["<template>\n  <div>\n    <div class=\"container-article\">\n      <div class=\"container\">\n        <section class=\"row\">\n          <div class=\"\">\n            <div class=\"col-lg-9 col-md-9 animated slideInLeft\">\n              <div class=\"article-list\">\n                <article\n                  class=\"item\"\n                  v-for=\"(item, index) in articleList\"\n                  :key=\"index\"\n                >\n                  <div class=\"art-item\">\n                    <div class=\"left-art-img\">\n                      <div class=\"art-img\">\n                        <a href=\"#\">\n                          <img\n                            v-lazy=\"\n                              item.indexPicture\n                                ? item.indexPicture\n                                : '/imgs/IMG_0541.JPG'\n                            \"\n                          />\n                        </a>\n                        <!-- class=\"animated hover_\" data-in=\"swing\" data-out=\"pulse\" -->\n                        <div class=\"overlay hidden-sm hidden-xs\">\n                          <h2>\n                            {{\n                              item.articleTitle ? item.articleTitle : \"title\"\n                            }}\n                          </h2>\n                          <router-link class=\"info\" :to=\"'/article/' + item.id\"\n                            >阅读</router-link\n                          >\n                        </div>\n                      </div>\n                    </div>\n                    <div class=\"right-art-abstract\">\n                      <div class=\"art-abstract-flex\">\n                        <div class=\"title\">\n                          <router-link :to=\"'/article/' + item.id\">{{\n                            item.articleTitle\n                              ? item.articleTitle\n                              : \"《maike市集》\"\n                          }}</router-link>\n                        </div>\n                        <div class=\"base-info\">\n                          <ul>\n                            <li class=\"hidden-xs\">\n                              <img\n                                v-lazy=\"require('@/assets/icon/mai.png')\"\n                                class=\"article_user_pic\"\n                              />\n                            </li>\n                            <li class=\"hidden-xs\">\n                              <a href=\"javascript:void(0);\">{{\n                                item.authorName ? item.authorName : \"geekcjj\"\n                              }}</a>\n                            </li>\n                            <li>\n                              {{\n                                item.createTime\n                                  ? getOnlyYearMonthDay(item.createTime)\n                                  : \"2015-04-04\"\n                              }}\n                            </li>\n                          </ul>\n                        </div>\n                        <div\n                          v-if=\"item.articleContent !== ''\"\n                          v-text=\"item.abstractText\"\n                          class=\"desc\"\n                        ></div>\n                        <div v-else class=\"desc\">\n                          这是一篇文章，虽然他没有文字，市集里最熟悉的陌生人，多年以后，我们又在繁华的市集相遇，伫立对视片刻，便擦肩而过，消失在了人潮中。\n                        </div>\n                      </div>\n                    </div>\n                  </div>\n                </article>\n\n                <!-- <article class=\"item\">\n                  <div class=\"art-item\">\n                    <div class=\"left-art-img\">\n                      <div class=\"art-img\">\n                        <img\n                          src=\"/imgs/ChMkJ1bKziaIU3lvAAgAJKmcCvEAALJIAFrDQAACAA8015.jpg\"\n                        />\n                      </div>\n                    </div>\n                    <div class=\"right-art-abstract\">\n                      <div class=\"art-abstract-flex\">\n                        <div class=\"title\">\n                          <a href=\"http://www.maike.com/detail_379.html\"\n                            >DIV+CSS静态HTML网页设计模板</a>\n                        </div>\