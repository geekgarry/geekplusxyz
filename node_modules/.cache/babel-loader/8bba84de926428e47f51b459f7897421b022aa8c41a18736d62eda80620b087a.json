{"ast":null,"code":"import GCLogo from \"@/assets/logo.png\";\nimport MKLogo from \"@/assets/icon/mai.png\";\n//调用回复消息的组件\nimport ReplyMessageBox from \"@/components/comment/ReplyMessageBox.vue\";\nimport { sendUserComment, getAllUserComment, getUserCommentCount, getLatestUserComment } from \"@/api/geekplus/geekplus\";\nexport default {\n  name: \"SubReplyMessage\",\n  //props: ['replyMessage'],\n  components: {\n    ReplyMessageBox\n  },\n  props: {\n    replyMessage: {\n      type: [Array, Object]\n    }\n  },\n  data: () => {\n    return {\n      GPLogo: GCLogo,\n      UserLogo: MKLogo,\n      isDisplayMsgBox: false,\n      replyBoxIndex: -1\n    };\n  },\n  created() {\n    //console.log(this.replyMessage);\n  },\n  methods: {\n    getReplyMessage(data) {\n      //console.log(data)\n      //replyMessage.push(data);\n      sendUserComment(data).then(response => {\n        console.log(response);\n        //this.getAllUserCommentMsg();\n        this.sendUserCommentRefresh(\"1\");\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n    openReplyBox(index) {\n      //this.isDisplayMsgBox = true;\n      this.replyBoxIndex = index;\n      console.log(this.replyBoxIndex);\n    },\n    closeReplyBox() {\n      //this.isDisplayMsgBox = false;\n      this.replyBoxIndex = -1;\n    },\n    sendUserCommentRefresh(para) {\n      //this.replMsg.replyId=messageId;\n      // 调用自定义事件，传入参数\n      this.$emit('sendUserCommentStatus', para);\n    }\n  }\n};","map":{"version":3,"names":["GCLogo","MKLogo","ReplyMessageBox","sendUserComment","getAllUserComment","getUserCommentCount","getLatestUserComment","name","components","props","replyMessage","type","Array","Object","data","GPLogo","UserLogo","isDisplayMsgBox","replyBoxIndex","created","methods","getReplyMessage","then","response","console","log","sendUserCommentRefresh","catch","error","openReplyBox","index","closeReplyBox","para","$emit"],"sources":["src/components/comment/SubReplyMessage.vue"],"sourcesContent":["<template>\n  <!-- 封装的一个递归显示留言和子留言 -->\n  <div>\n    <div\n      class=\"comment-lw\"\n      v-for=\"(subitem, index) in replyMessage\"\n      :key=\"index\"\n    >\n      <div class=\"comment-main\">\n        <a class=\"user-logo\"><img :src=\"UserLogo\" /></a>\n        <div class=\"comment-content\">\n          <div class=\"comment-info\">\n            <a>{{ subitem.name }}</a\n            ><span>{{ subitem.createTime }}</span>\n          </div>\n          <div class=\"comment-text\">\n            {{ subitem.content }}\n          </div>\n          <div class=\"comment-action\">\n            <!-- <a href=\"javascript:void(0)\" selfid=\"6\">回复</a> -->\n            <a href=\"javascript:void(0)\" @click=\"openReplyBox(subitem.id)\">回复</a>\n            &nbsp;\n            <a\n              v-if=\"replyBoxIndex===subitem.id\"\n              href=\"javascript:void(0)\"\n              @click=\"closeReplyBox\"\n              >关闭</a\n            >\n          </div>\n          <reply-message-box\n            v-if=\"replyBoxIndex===subitem.id\" \n            v-on:getReplyMsg=\"getReplyMessage\"\n            :messageId=\"subitem.id\"\n            ref=\"replyMsgRef\"\n          ></reply-message-box>\n        </div>\n      </div>\n      <div v-if=\"subitem.replyMessage\" class=\"sub-comment-lw\">\n        <sub-reply-message\n          :replyMessage=\"subitem.replyMessage\"\n        ></sub-reply-message>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport GCLogo from \"@/assets/logo.png\";\nimport MKLogo from \"@/assets/icon/mai.png\";\n//调用回复消息的组件\nimport ReplyMessageBox from \"@/components/comment/ReplyMessageBox.vue\";\nimport {sendUserComment,getAllUserComment,getUserCommentCount,getLatestUserComment} from \"@/api/geekplus/geekplus\"\n\nexport default {\n  name: \"SubReplyMessage\",\n  //props: ['replyMessage'],\n  components: {\n    ReplyMessageBox,\n  },\n  props: {\n    replyMessage: {\n      type: [Array, Object],\n    },\n  },\n  data: () => {\n    return {\n      GPLogo: GCLogo,\n      UserLogo: MKLogo,\n      isDisplayMsgBox:false,\n      replyBoxIndex:-1,\n    };\n  },\n  created() {\n    //console.log(this.replyMessage);\n  },\n  methods: {\n    getReplyMessage(data){\n      //console.log(data)\n      //replyMessage.push(data);\n      sendUserComment(data).then(response => {\n        console.log(response)\n        //this.getAllUserCommentMsg();\n        this.sendUserCommentRefresh(\"1\")\n      }).catch(error => {\n        console.log(error)\n      })\n    },\n    openReplyBox(index) {\n      //this.isDisplayMsgBox = true;\n      this.replyBoxIndex=index;\n      console.log(this.replyBoxIndex)\n    },\n    closeReplyBox() {\n      //this.isDisplayMsgBox = false;\n      this.replyBoxIndex=-1;\n    },\n    sendUserCommentRefresh(para){\n      //this.replMsg.replyId=messageId;\n        // 调用自定义事件，传入参数\n        this.$emit('sendUserCommentStatus',para)\n    },\n  },\n};\n</script>\n\n<style>\n</style>"],"mappings":"AA+CA,OAAAA,MAAA;AACA,OAAAC,MAAA;AACA;AACA,OAAAC,eAAA;AACA,SAAAC,eAAA,EAAAC,iBAAA,EAAAC,mBAAA,EAAAC,oBAAA;AAEA;EACAC,IAAA;EACA;EACAC,UAAA;IACAN;EACA;EACAO,KAAA;IACAC,YAAA;MACAC,IAAA,GAAAC,KAAA,EAAAC,MAAA;IACA;EACA;EACAC,IAAA,EAAAA,CAAA;IACA;MACAC,MAAA,EAAAf,MAAA;MACAgB,QAAA,EAAAf,MAAA;MACAgB,eAAA;MACAC,aAAA;IACA;EACA;EACAC,QAAA;IACA;EAAA,CACA;EACAC,OAAA;IACAC,gBAAAP,IAAA;MACA;MACA;MACAX,eAAA,CAAAW,IAAA,EAAAQ,IAAA,CAAAC,QAAA;QACAC,OAAA,CAAAC,GAAA,CAAAF,QAAA;QACA;QACA,KAAAG,sBAAA;MACA,GAAAC,KAAA,CAAAC,KAAA;QACAJ,OAAA,CAAAC,GAAA,CAAAG,KAAA;MACA;IACA;IACAC,aAAAC,KAAA;MACA;MACA,KAAAZ,aAAA,GAAAY,KAAA;MACAN,OAAA,CAAAC,GAAA,MAAAP,aAAA;IACA;IACAa,cAAA;MACA;MACA,KAAAb,aAAA;IACA;IACAQ,uBAAAM,IAAA;MACA;MACA;MACA,KAAAC,KAAA,0BAAAD,IAAA;IACA;EACA;AACA"},"metadata":{},"sourceType":"module","externalDependencies":[]}