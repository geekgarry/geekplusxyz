on) {\n            window.scrollTo(0, this.backPosition)\n            clearInterval(this.interval)\n          } else{\n            window.scrollTo(0, next)\n          }\n          i++\n        }, 17)\n      },\n      /*\n        缓动公式（Tween算法）\n         t: 动画已经执行的时间（实际上时执行多少次/帧数）\n         b: 起始位置\n         c: 终止位置\n         d: 从起始位置到终止位置的经过时间（实际上时执行多少次/帧数）\n  \n        http://www.cnblogs.com/mrsunny/archive/2011/06/21/2086080.html\n      */\n      easeInOutQuad(t, b, c, d) {\n        // 判断当前时间是否总在总时间的一半以内，是的话执行缓入函数，否则的话执行缓出函数\n        if ((t /= d / 2) < 1) { \n          return c / 2 * t * t + b\n        } else {\n          // 将总长度设置为一半，并且时间从当前开始递减，对图像进行垂直向上平移\n          return -c / 2 * (--t * (t - 2) - 1) + b\n        }\n      }\n    }\n  }\n  </script>\n  \n  <style lang=\"scss\" scoped>\n  /* 类名要对应回 name 的属性值 */\n  .plusBack-enter-active {\n    animation: move 1s;\n  }\n  .plusBack-leave-active {\n    animation: move 1s reverse;\n  }\n  @keyframes move {\n    from {\n        transform: translateX(-100%);\n    }\n    to {\n        transform: translate(0);\n    }\n  }\n  .page-component-up{\n    position: fixed;\n    cursor: pointer;\n    text-align: center;\n    transition: .3s;\n    box-shadow: 0 0 6px rgba(0,0,0,.12);\n    z-index: 99;\n    i{\n      color: #409eff;\n      display: block;\n      line-height: inherit;\n      text-align: center;\n      font-size: 18px;\n    }\n  }\n  </style>"],"mappings":";;;;;;eAeA;EACAA,IAAA;EACAC,KAAA;IACAC,cAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAC,WAAA;MACAH,IAAA,EAAAI;IACA;IACAC,gBAAA;MAAA;MACAL,IAAA,EAAAM;IACA;IACAC,YAAA;MAAA;MACAP,IAAA,EAAAM,MAAA;MACAJ,OAAA;IACA;EACA;EACAM,KAAA;IACA;MACAC,OAAA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACAC,MAAA,CAAAC,gBAAA,gBAAAC,YAAA;EACA;EACAC,cAAA;IACAH,MAAA,CAAAI,mBAAA,gBAAAF,YAAA;IACA,SAAAJ,QAAA;MACAO,aAAA,MAAAP,QAAA;IACA;EACA;EACAQ,OAAA;IACAJ,aAAA;MACA,KAAAL,OAAA,GAAAG,MAAA,CAAAO,WAAA,QAAAd,gBAAA;IACA;IACAe,UAAA;MACA,IAAAC,SAAA,GAAAT,MAAA,CAAAO,WAAA;MACA,IAAAG,CAAA;MACA,KAAAZ,QAAA,GAAAa