{"ast":null,"code":"import BackToTop from \"@/components/BackToTop\";\n// import WaveItem from \"@/components/effect/Wave\";\nimport maiLogo from \"@/assets/icon/mai.png\";\nimport { displayFriendlyLink } from \"@/api/geekplus/geekplus\";\nexport default {\n  components: {\n    BackToTop\n    //WaveItem,\n  },\n\n  data() {\n    return {\n      theme1: \"light\",\n      visible: false,\n      contentScrollTop: 0,\n      isBackTop: false,\n      //显示返回顶部按钮\n      menuList: [],\n      //导航栏菜单\n      friendlyLinkList: [],\n      clickCurrentMenu: false,\n      levelList: [],\n      //面包屑菜单\n      transName: \"plusBack\",\n      //变化动画名称前缀\n      myBackToTopStyle: {\n        //自定义响应式plushome.css,不用这个\n        // 'right': '100px',\n        // 'bottom': '150px',\n        // 'width': '40px',\n        // 'height': '40px',\n        // 'border-radius': '20px',\n        // 'line-height': '40px',\n        // 'background': '#fff'\n      },\n      GCLogo: require(\"@/assets/logo.png\"),\n      MKLogo: maiLogo,\n      topNavBarFixed: 'navbar navbar-default navbar-static-top',\n      navBarStyle: '',\n      keywords: '' //搜索关键词\n    };\n  },\n\n  created() {\n    this.getMneuList();\n    this.getBreadcrumb();\n    this.displayWebFriendlyLink();\n  },\n  mounted() {\n    window.onscroll = () => {\n      return (() => {\n        var st = document.documentElement.scrollTop || document.body.scrollTop;\n        this.contentScrollTop = st;\n        //console.log(st);\n        // if (t > 150) {\n        //             // $('#navigator_bar').css('position', 'fixed');\n        //             // $('#navigator_bar').css('top', '0px');\n        //     document.getElementById(\"navigator_bar\").getAttribute(\"class\")=\"navbar navbar-default navbar-static-top navbar-fixed-top animated slideInDown\";\n        //     document.getElementsByClassName(\"banner_slider\").style.marginTop=51+'px';\n        //             //$('#navigator_bar').css('');\n        //         } else {\n        //           document.getElementById(\"navigator_bar\").getAttribute(\"class\")=\"navbar navbar-default navbar-static-top\";\n        //     document.getElementsByClassName(\"banner_slider\").style.marginTop=0+'px';\n        //             //$('#navigator_bar').css('position', '');\n        //         }\n        //         if (t>750){//判断滚动后高度超过750px,就显示\n        //           document.getElementById(\"backToTop\").fadeIn(1100);//淡入\n        //         }\n        //         else\n        //         {\n        //           document.getElementById(\"backToTop\").stop().fadeOut(1100); //如果返回或者没有超过,就淡出.必须加上stop()停止之前动画,否则会出现闪动//.fadeOut(1500);\n        //         }\n      })();\n      //this.$refs.friendlinkA.tooltip();\n    };\n    // var a_idx = 0;\n    // document.addEventListener(\"onreadystatechange\",function () {\n    //   alert(\"i你背包\")\n    //   document.body.addEventListener(\"onclick\", function (e) {\n    //     var a = new Array(\"三民主义\", \"民族\", \"民权\", \"民生\");\n    //     var ii = document.createElement(\"span\").text(a[a_idx]);\n    //     a_idx = (a_idx + 1) % a.length;\n    //     var x = e.pageX,\n    //       y = e.pageY;\n    //     ii.css({\n    //       \"z-index\": 9999999,\n    //       top: y - 20,\n    //       left: x,\n    //       position: \"absolute\",\n    //       \"font-weight\": \"bold\",\n    //       color: \"#ff6651\",\n    //     });\n    //     document.body.innerHTML += ii;\n    //     ii.animate(\n    //       {\n    //         top: y - 180,\n    //         opacity: 0,\n    //       },\n    //       1500,\n    //       function () {\n    //         ii.remove();\n    //       }\n    //     );\n    //   });\n    // });\n  },\n\n  watch: {\n    contentScrollTop(val) {\n      let that = this;\n      //console.log(\"实时屏幕滚动高度：\", val, that.contentScrollTop);\n      //chatHeight=that.windowHeight\n      //var backToTop = document.getElementById(\"backToTop\");\n      if (val > 150 && val < 350) {\n        that.topNavBarFixed = \"navbar navbar-default navbar-static-top navbar-fixed-top animate__animated animate__slideInDown\";\n        that.navBarStyle = \"margin-top:75px;\";\n      } else if (val > 350 || val < 150) {\n        that.topNavBarFixed = \"navbar navbar-default navbar-static-top animate__animated animate__fadeInUp\";\n        that.navBarStyle = \"margin-top:0px;\";\n      }\n      if (val > 750) {\n        //alert(\"你好\")\n        //判断滚动后高度超过750px,就显示\n        //backToTop.fadeIn(1100);//淡入\n        that.isBackTop = true;\n      } else {\n        //backToTop.stop().fadeOut(1100); //如果返回或者没有超过,就淡出.必须加上stop()停止之前动画,否则会出现闪动//.fadeOut(1500);\n        that.isBackTop = false;\n      }\n    }\n  },\n  methods: {\n    /** 首页显示友情链接 */\n    displayWebFriendlyLink() {\n      displayFriendlyLink().then(response => {\n        this.friendlyLinkList = response.data;\n      }).catch(error => {\n        console.log(error.msg);\n      });\n    },\n    backToTopBtn() {\n      //document.documentElement.scrollTop = 0;\n      let top = document.documentElement.scrollTop || document.body.scrollTop;\n      // 实现滚动效果\n      const timeTop = setInterval(() => {\n        document.body.scrollTop = document.documentElement.scrollTop = top -= 50;\n        if (top <= 0) {\n          clearInterval(timeTop);\n        }\n      }, 10);\n    },\n    backToTop() {\n      document.documentElement.scrollTop = 0;\n      //document.getElementsByName(\"html,body\").animate({scrollTop:\"0px\"},500);\n    },\n\n    handleOpen() {\n      this.visible = true;\n    },\n    handleClose() {\n      this.visible = false;\n    },\n    mouseOverIt() {\n      this.GCLogo = require(\"@/assets/logo.png\");\n    },\n    mouseOutIt() {\n      this.GCLogo = require(\"@/assets/logo.png\");\n    },\n    getMneuList() {\n      // let matched = this.$route.matched.filter(\n      //   (item) => item.meta && item.meta.title\n      // );\n      //this.menuList=this.$router.options.routes;\n      this.menuList = this.$router.options.routes.filter(item => item.type === 'menu');\n      //matched = this.menuList.concat(matched);\n      // this.menuList = matched.filter(\n      //   (item) => item.meta && item.meta.title && item.meta.breadcrumb !== false\n      // );\n      console.log(this.menuList);\n    },\n    getBreadcrumb() {\n      let matched = this.$route.matched.filter(item => item.meta && item.meta.title);\n      const first = matched[0];\n      console.log(this.$route.fullPath);\n      if (!this.isHome(first)) {\n        matched = [{\n          path: \"/\",\n          meta: {\n            title: \"首页\"\n          }\n        }].concat(matched);\n      }\n      this.levelList = matched.filter(item => item.meta && item.meta.title !== false);\n      console.log(matched);\n      console.log(this.levelList);\n    },\n    isHome(route) {\n      const name = route && route.name;\n      if (!name) {\n        return false;\n      }\n      return name.trim().toLocaleLowerCase() === \"home\".toLocaleLowerCase();\n    },\n    getMenuActive() {\n      this.clickCurrentMenu = true;\n    }\n  }\n};","map":{"version":3,"names":["BackToTop","maiLogo","displayFriendlyLink","components","data","theme1","visible","contentScrollTop","isBackTop","menuList","friendlyLinkList","clickCurrentMenu","levelList","transName","myBackToTopStyle","GCLogo","require","MKLogo","topNavBarFixed","navBarStyle","keywords","created","getMneuList","getBreadcrumb","displayWebFriendlyLink","mounted","window","onscroll","st","document","documentElement","scrollTop","body","watch","val","that","methods","then","response","catch","error","console","log","msg","backToTopBtn","top","timeTop","setInterval","clearInterval","backToTop","handleOpen","handleClose","mouseOverIt","mouseOutIt","$router","options","routes","filter","item","type","matched","$route","meta","title","first","fullPath","isHome","path","concat","route","name","trim","toLocaleLowerCase","getMenuActive"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <!-- <nav>\n      <router-link to=\"/\">Home</router-link> |\n      <router-link to=\"/about\">About</router-link>\n    </nav>\n    <router-view/> -->\n    <header class=\"header\">\n      <div class=\"container\">\n        <div class=\"row\">\n          <div class=\"logo\">\n            <img\n              v-lazy=\"GCLogo\"\n              class=\"top_banner_logo\"\n              @mouseover=\"mouseOverIt\"\n              @mouseout=\"mouseOutIt\"\n            />\n            <span class=\"logo-text navbar-collapse collapse animated rotateIn\"\n              >极客普拉斯</span\n            >\n          </div>\n          <div class=\"right-block\">\n            <div class=\"wow pulse bg-yellow\" data-wow-delay=\"0.1s\">人生，</div>\n            <div\n              class=\"wow rollIn bg-red\"\n              data-wow-iteration=\"1\"\n              data-wow-duration=\"0.5s\"\n            >\n              就像一盒巧克力，\n            </div>\n            <div class=\"wow bounceInRight bg-blue\">\n              你永远不知道下一块会是什么味道！\n            </div>\n            <div class=\"wow bounceInRight bg-blue\">---《阿甘正传》</div>\n          </div>\n        </div>\n      </div>\n    </header>\n    <!-- <div class=\"gc-slide\">\n      <div class=\"gc_hand_top\" id=\"backToTop\">\n        <a href=\"javascript:void(0);\" class=\"gc_hand_top_btn\"\n          ><i class=\"gcfont\"></i><span>返回顶部</span></a\n        >\n      </div>\n    </div> -->\n    <nav :class=\"topNavBarFixed\" id=\"navigator_bar\">\n      <div class=\"container\">\n        <div class=\"navbar-header\">\n          <button class=\"navbar-toggle pull-right\">\n            <span class=\"glyphicon glyphicon-road\" aria-hidden=\"true\"\n              ></span\n            >\n          </button>\n          <button\n            class=\"navbar-toggle pull-right\"\n            data-toggle=\"collapse\"\n            data-target=\"#collapse_searche_div\"\n          >\n            <span class=\"glyphicon glyphicon-search\"></span>\n          </button>\n          <button\n            class=\"navbar-toggle pull-right\"\n            data-toggle=\"collapse\"\n            data-target=\"#navbar_collapse_div\"\n          >\n            <span class=\"icon-bar\"></span>\n            <span class=\"icon-bar\"></span>\n            <span class=\"icon-bar\"></span>\n          </button>\n          <!-- <a class=\"navbar-brand\" href=\"#\">\n                                  <img src=\"images/mai.png\" class=\"logo_img\" onmouseover=\"this.src='images/mai.jpg'\"\n                                      onmouseout=\"this.src='images/mai.png'\" style=\"width:22px;height:22px;\" />\n                              </a> -->\n          <a class=\"navbar-brand visible-xs\" href=\"https://www.geekplus.xyz/\"\n            >极客普拉斯</a\n          >\n        </div>\n        <div class=\"collapse animated fadeInDown\" id=\"collapse_searche_div\">\n          <div class=\"search_bar_top\">\n            <!-- <form action=\"/searchResult\" class=\"input-group input-group-lg\">\n              <input type=\"text\" class=\"form-control\" placeholder=\"请输入您要搜索的内容...\">\n              <span class=\"input-group-btn\">\n                <button class=\"btn btn-default\" type=\"submit\">\n                  <span class=\"glyphicon glyphicon-search\" aria-hidden=\"true\"></span>\n                </button>\n              </span>\n            </form> -->\n            <form action=\"\">\n              <input\n                type=\"text\"\n                class=\"form-control\"\n                placeholder=\"请输入您要搜索的内容...\"\n                name=\"keywords\"\n                v-model=\"keywords\"\n              />\n              <button type=\"submit\">\n                <span class=\"glyphicon glyphicon-search\" aria-hidden=\"true\"></span>\n              </button>\n            </form>\n          </div>\n        </div>\n        <div class=\"navbar-collapse collapse\" id=\"navbar_collapse_div\">\n          <ul class=\"nav navbar-nav navbar-left navbar_ul\">\n            <li :class=\"isHome&&index===0?'menuactive':''\" @click=\"getMenuActive()\" v-for=\"(item,index) in menuList\" :key=\"index\">\n              <a :href=\"item.path\">{{ item.meta.title }}</a>\n            </li>\n            <!-- <li>\n              <a href=\"/blogArtices\">编程技术</a>\n            </li>\n            <li>\n              <a href=\"/newTalkList\">新闻杂谈</a>\n            </li>\n\n            <li>\n              <a href=\"/resourceDownload\">资源文件</a>\n            </li>\n\n            <li>\n              <a href=\"javascript:0;\">生活随笔</a>\n              <div class=\"itembox\">\n                <ul>\n                  <li><a href=\"/thinkingLife\">格物生活</a></li>\n                  <li><a href=\"/personalEssay\">个人随笔</a></li>\n                </ul>\n              </div>\n            </li>\n\n            <li>\n              <a href=\"/leavemessage-board\">给我留言</a>\n            </li>\n            <li>\n              <a href=\"/about\">关于梦极客园</a>\n            </li> -->\n          </ul>\n          <ul class=\"nav navbar-nav navbar-right hidden-sm\">\n            <li><a href=\"https://maikeadmin.geekplus.xyz/chat\">ChatGPT智能助手<span class=\"badge\"></span></a></li>\n            <!-- <li class=\"dropdown\">\n              <a\n                href=\"#\"\n                class=\"dropdown-toggle\"\n                data-toggle=\"dropdown\"\n                role=\"button\"\n                aria-haspopup=\"true\"\n                aria-expanded=\"false\"\n                >梦极客<span class=\"caret\"></span\n              ></a>\n              <ul class=\"dropdown dropdown-menu navbar_ul\">\n                <li><a href=\"#\">个人中心</a></li>\n                <li><a href=\"#\">我的收藏</a></li>\n                <li><a href=\"#\">账号设置</a></li>\n                <li role=\"separator\" class=\"divider\"></li>\n                <li><a href=\"#\">退出</a></li>\n              </ul>\n            </li> -->\n          </ul>\n        </div>\n      </div>\n    </nav>\n\n    <back-to-top\n      class=\"hidden-xs hidden-sm\"\n      :transitionName=\"transName\"\n      :customStyle=\"myBackToTopStyle\"\n      :visibilityHeight=\"600\"\n      :backPosition=\"150\" >\n    </back-to-top>\n    \n    <!-- <wave-item></wave-item> -->\n    \n    <div :style=\"navBarStyle\"><router-view /></div>\n    \n    <!-- <div class=\"gc-slide\" v-if=\"isBackTop\">\n      <div class=\"gc_hand_top\" id=\"backToTop\">\n        <a\n          href=\"javascript:void(0);\"\n          @click=\"backToTop\"\n          class=\"gc_hand_top_btn\"\n        >\n          <span class=\"glyphicon glyphicon-search\" aria-hidden=\"true\"></span>\n          <img\n            v-if=\"isBackTop\"\n            class=\"go-top\"\n            src=\"imgs/bloglogo.png\"\n            @click=\"backToTop\"\n          />\n          <i class=\"gcfont\"></i><span>返回顶部</span>\n        </a>\n      </div>\n    </div> -->\n    <nav\n      class=\"navbar navbar-default navbar-fixed-bottom visible-xs visible-sm\"\n    >\n      <div class=\"container\">\n        <div class=\"row\">\n          <div class=\"col-xs-3 col-sm-3 text-center\">\n            <!-- 行内跳转方式(同样可以传参)： -->\n            <div class=\"bg-secondary\" @click=\"$router.push('/')\">\n              <div class=\"\">\n                <span class=\"glyphicon glyphicon-home\"></span>\n              </div>\n              <div class=\"navbar-fixed-text-size\">\n                <small>主页</small>\n              </div>\n            </div>\n          </div>\n          <div class=\"col-xs-3 col-sm-3 text-center\">\n            <div class=\"bg-secondary\">\n              <div class=\"\">\n                <span class=\"glyphicon glyphicon-equalizer\"></span>\n              </div>\n              <div class=\"navbar-fixed-text-size\">\n                <small>待定</small>\n              </div>\n            </div>\n          </div>\n          <div class=\"col-xs-3 col-sm-3 text-center\">\n            <!-- @click=\"$router.push('/leaveMessage')\" -->\n            <div class=\"bg-secondary\">\n              <router-link to=\"/leaveMessage\">\n                <div class=\"\">\n                  <span class=\"glyphicon glyphicon-comment\"></span>\n                </div>\n                <div class=\"navbar-fixed-text-size\">\n                  <small>留言</small>\n                </div>\n              </router-link>\n            </div>\n          </div>\n          <div class=\"col-xs-3 col-sm-3 text-center\">\n            <div class=\"bg-secondary\" @click=\"backToTopBtn\">\n              <div class=\"\">\n                <span class=\"glyphicon glyphicon-menu-up\"></span>\n              </div>\n              <div class=\"navbar-fixed-text-size\">\n                <small>顶部</small>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </nav>\n    <div class=\"friendlink_container\">\n      <div class=\"container\">\n        <div class=\"row\">\n          <div class=\"col-md-12\">\n            <div class=\"friendlink_title\"><label>友情链接:</label></div>\n            <div class=\"friendlink_content\" id=\"friendlink_content\">\n              <a class=\"friendlink_a\" ref=\"friendlinkA\" data-toggle=\"tooltip\" :title=\"item.linkIntro\" v-for=\"(item,index) in friendlyLinkList\" :key=\"index\" :href=\"item.linkUrl\">{{item.linkName}}</a>\n              <!-- <a class=\"friendlink_a\" href=\"https://www.maikete.xyz\">麦科特</a> -->\n              <!-- <a class=\"friendlink_a\" href=\"https://www.chitang.club\">小池塘</a> -->\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n    <div class=\"custom_footer\">\n      <div class=\"container\">\n        <div class=\"row\">\n          <div class=\"col-md-12 text-center\">\n            <!-- <h2>GEEKCJJ<span style=\"color:#FF6347;\">'S</span> 梦极客园</h2> -->\n            <p>\n              由<a\n                href=\"http://www.geekplus.xyz\"\n                target=\"_blank\"\n                style=\"color: white; text-decoration: underline\"\n                >极客普拉斯</a\n              >提供技术支持\n            </p>\n            <p>\n              © 2018－2019 geekplus.xyz, all rights reserved &nbsp;<a\n                href=\"http://beian.miit.gov.cn\"\n                target=\"_blank\"\n                >苏ICP备19023267号-3</a\n              >\n            </p>\n            <p>\n              <a href=\"http://beian.miit.gov.cn\" target=\"_blank\"\n                >苏ICP备19023267号-3 &amp;</a\n              >\n            </p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport BackToTop from \"@/components/BackToTop\";\n// import WaveItem from \"@/components/effect/Wave\";\nimport maiLogo from \"@/assets/icon/mai.png\";\nimport {displayFriendlyLink} from \"@/api/geekplus/geekplus\"\nexport default {\n  components: {\n    BackToTop,\n    //WaveItem,\n  },\n  data() {\n    return {\n      theme1: \"light\",\n      visible: false,\n      contentScrollTop: 0,\n      isBackTop: false, //显示返回顶部按钮\n      menuList: [], //导航栏菜单\n      friendlyLinkList:[],\n      clickCurrentMenu:false,\n      levelList: [], //面包屑菜单\n      transName: \"plusBack\", //变化动画名称前缀\n      myBackToTopStyle: {\n        //自定义响应式plushome.css,不用这个\n        // 'right': '100px',\n        // 'bottom': '150px',\n        // 'width': '40px',\n        // 'height': '40px',\n        // 'border-radius': '20px',\n        // 'line-height': '40px',\n        // 'background': '#fff'\n      },\n      GCLogo: require(\"@/assets/logo.png\"),\n      MKLogo: maiLogo,\n      topNavBarFixed:'navbar navbar-default navbar-static-top',\n      navBarStyle:'',\n      keywords:'',//搜索关键词\n    };\n  },\n  created() {\n    this.getMneuList();\n    this.getBreadcrumb();\n    this.displayWebFriendlyLink();\n  },\n  mounted() {\n    window.onscroll = () => {\n      return (() => {\n        var st = document.documentElement.scrollTop || document.body.scrollTop;\n        this.contentScrollTop = st;\n        //console.log(st);\n        // if (t > 150) {\n      