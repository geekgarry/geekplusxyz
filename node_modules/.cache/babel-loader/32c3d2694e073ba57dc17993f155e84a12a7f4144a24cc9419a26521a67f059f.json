{"ast":null,"code":"\"use strict\";\n\nvar _interopRequireDefault = require(\"/Users/MyProjectBase/Vue/geekplusxyz/node_modules/@babel/runtime/helpers/interopRequireDefault.js\").default;\nObject.defineProperty(exports, \"__esModule\", {\n  value: true\n});\nexports.default = void 0;\nrequire(\"core-js/modules/es.array.push.js\");\nvar _index = _interopRequireDefault(require(\"@/store/index\"));\nvar _BackToTop = _interopRequireDefault(require(\"@/components/BackToTop\"));\nvar _mai = _interopRequireDefault(require(\"@/assets/icon/mai.png\"));\nvar _geekplus = require(\"@/api/geekplus/geekplus\");\nvar _dynamicrouter = require(\"@/utils/dynamicrouter\");\nvar _AppMain = _interopRequireDefault(require(\"./components/AppMain\"));\n// import WaveItem from \"@/components/effect/Wave\";\nvar _default = {\n  name: \"Layout\",\n  components: {\n    BackToTop: _BackToTop.default,\n    AppMain: _AppMain.default\n    //WaveItem,\n  },\n\n  data() {\n    return {\n      theme1: \"light\",\n      visible: false,\n      contentScrollTop: 0,\n      isBackTop: false,\n      //显示返回顶部按钮\n      menuList: [],\n      //导航栏菜单\n      friendlyLinkList: [],\n      dynamicsMenuRouter: [],\n      levelList: [],\n      //面包屑菜单\n      transName: \"plusBack\",\n      //变化动画名称前缀\n      myBackToTopStyle: {\n        //自定义响应式plushome.css,不用这个\n        // 'right': '100px',\n        // 'bottom': '150px',\n        // 'width': '40px',\n        // 'height': '40px',\n        // 'border-radius': '20px',\n        // 'line-height': '40px',\n        // 'background': '#fff'\n      },\n      GCLogo: require(\"@/assets/logo.png\"),\n      MKLogo: _mai.default,\n      topNavBarFixed: \"navbar navbar-default navbar-static-top\",\n      navBarStyle: \"\",\n      keywords: \"\",\n      //搜索关键词\n      subParentCategoryList: [],\n      webHeaderFooterInfo: {}\n    };\n  },\n  computed: {\n    keyPath() {\n      return this.$route.path;\n    }\n  },\n  created() {\n    //this.listGeekplusCategory();\n    this.getMneuList();\n    this.getBreadcrumb();\n    this.displayWebFriendlyLink();\n    this.getWebTitleNameFooterInfo();\n  },\n  mounted() {\n    window.onscroll = () => {\n      return (() => {\n        var st = document.documentElement.scrollTop || document.body.scrollTop;\n        this.contentScrollTop = st;\n        //console.log(st);\n        // if (t > 150) {\n        //             // $('#navigator_bar').css('position', 'fixed');\n        //             // $('#navigator_bar').css('top', '0px');\n        //     document.getElementById(\"navigator_bar\").getAttribute(\"class\")=\"navbar navbar-default navbar-static-top navbar-fixed-top animated slideInDown\";\n        //     document.getElementsByClassName(\"banner_slider\").style.marginTop=51+'px';\n        //             //$('#navigator_bar').css('');\n        //         } else {\n        //           document.getElementById(\"navigator_bar\").getAttribute(\"class\")=\"navbar navbar-default navbar-static-top\";\n        //     document.getElementsByClassName(\"banner_slider\").style.marginTop=0+'px';\n        //             //$('#navigator_bar').css('position', '');\n        //         }\n        //         if (t>750){//判断滚动后高度超过750px,就显示\n        //           document.getElementById(\"backToTop\").fadeIn(1100);//淡入\n        //         }\n        //         else\n        //         {\n        //           document.getElementById(\"backToTop\").stop().fadeOut(1100); //如果返回或者没有超过,就淡出.必须加上stop()停止之前动画,否则会出现闪动//.fadeOut(1500);\n        //         }\n      })();\n      //this.$refs.friendlinkA.tooltip();\n    };\n    // <!--把window.onresize事件挂在到mounted函数上-->\n    window.onresize = () => {\n      return (() => {\n        var hheight = window.fullHeight || document.documentElement.clientHeight;\n        var wwidth = window.fullWidth || document.documentElement.clientWidth;\n        this.windowHeight = hheight; // 高\n        this.windowWidth = wwidth; // 宽\n        // 页面宽度小于750px时，不显示地图\n        // if (that.windowWidth < 750) {\n        //   that.chatbtndisplay = false;\n        //   that.chatdisplay=true;\n        // } else {\n        //   that.chatbtndisplay = true;\n        //   that.chatdisplay=false;\n        // }\n        //console.log(\"页面高度：\"+that.windowHeight)\n      })();\n    };\n    // var a_idx = 0;\n    // document.addEventListener(\"onreadystatechange\",function () {\n    //   alert(\"i你背包\")\n    //   document.body.addEventListener(\"onclick\", function (e) {\n    //     var a = new Array(\"三民主义\", \"民族\", \"民权\", \"民生\");\n    //     var ii = document.createElement(\"span\").text(a[a_idx]);\n    //     a_idx = (a_idx + 1) % a.length;\n    //     var x = e.pageX,\n    //       y = e.pageY;\n    //     ii.css({\n    //       \"z-index\": 9999999,\n    //       top: y - 20,\n    //       left: x,\n    //       position: \"absolute\",\n    //       \"font-weight\": \"bold\",\n    //       color: \"#ff6651\",\n    //     });\n    //     document.body.innerHTML += ii;\n    //     ii.animate(\n    //       {\n    //         top: y - 180,\n    //         opacity: 0,\n    //       },\n    //       1500,\n    //       function () {\n    //         ii.remove();\n    //       }\n    //     );\n    //   });\n    // });\n  },\n\n  watch: {\n    contentScrollTop(val) {\n      let that = this;\n      console.log(\"实时屏幕滚动高度：\", val, that.contentScrollTop);\n      //chatHeight=that.windowHeight\n      //var backToTop = document.getElementById(\"backToTop\");\n      if (val > 150 && val < 770) {\n        that.topNavBarFixed = \"navbar navbar-default navbar-static-top navbar-fixed-top animate__animated animate__slideInDown\";\n        that.navBarStyle = \"margin-top:75px;\";\n      } else if (val > 770 || val < 150) {\n        that.topNavBarFixed = \"navbar navbar-default navbar-static-top animate__animated animate__fadeInUp\";\n        that.navBarStyle = \"margin-top:0px;\";\n      }\n      if (val > 750) {\n        //alert(\"你好\")\n        //判断滚动后高度超过750px,就显示\n        //backToTop.fadeIn(1100);//淡入\n        that.isBackTop = true;\n      } else {\n        //backToTop.stop().fadeOut(1100); //如果返回或者没有超过,就淡出.必须加上stop()停止之前动画,否则会出现闪动//.fadeOut(1500);\n        that.isBackTop = false;\n      }\n    },\n    windowHeight(val) {\n      let that = this;\n      console.log(\"实时屏幕高度：\", val, that.windowHeight);\n      //chatHeight=that.windowHeight\n    },\n\n    windowWidth(val) {\n      let that = this;\n      console.log(\"实时屏幕宽度：\", val, that.windowHeight);\n    },\n    $route: {\n      handler: function (val, oldVal) {\n        //console.log(val);\n      },\n      // 深度观察监听\n      deep: true\n    }\n  },\n  methods: {\n    getPath() {\n      //console.log(this.$route.path);\n      return this.$route.path;\n    },\n    /** 首页显示友情链接 */\n    displayWebFriendlyLink() {\n      (0, _geekplus.displayFriendlyLink)().then(response => {\n        this.friendlyLinkList = response.data;\n        //console.log(response)\n      }).catch(error => {\n        console.log(error.msg);\n      });\n    },\n    getWebTitleNameFooterInfo() {\n      let queryParams = {\n        id: 1\n      };\n      (0, _geekplus.getGpWebTitleInfo)(queryParams).then(response => {\n        console.log(response);\n        this.webHeaderFooterInfo = response.data;\n      }).catch(error => {\n        console.log(error);\n      });\n    },\n    backToTopBtn() {\n      //document.documentElement.scrollTop = 0;\n      let top = document.documentElement.scrollTop || document.body.scrollTop;\n      // 实现滚动效果\n      const timeTop = setInterval(() => {\n        document.body.scrollTop = document.documentElement.scrollTop = top -= 50;\n        if (top <= 0) {\n          clearInterval(timeTop);\n        }\n      }, 10);\n    },\n    //动态滚动到顶部\n    afterBackToTop(num) {\n      //document.documentElement.scrollTop = 0;\n      // 实现滚动效果\n      const timeTop = setInterval(() => {\n        document.body.scrollTop = document.documentElement.scrollTop = num;\n        if (top <= 0) {\n          clearInterval(timeTop);\n        }\n      }, 10);\n    },\n    handleOpen() {\n      this.visible = true;\n    },\n    handleClose() {\n      this.visible = false;\n    },\n    mouseOverIt() {\n      this.GCLogo = require(\"@/assets/logo.png\");\n    },\n    mouseOutIt() {\n      this.GCLogo = require(\"@/assets/logo.png\");\n    },\n    getMneuList() {\n      let that = this;\n      let tempMenuList = new Array();\n      // let matched = this.$route.matched.filter(\n      //   (item) => item.meta && item.meta.title\n      // );\n      tempMenuList = that.$router.options.routes.filter(item => item.type === \"layout\");\n      //that.menuList=getChildrenPath();\n      //console.log(that.menuList.length)\n      // deep(mmm).forEach((item) => {\n      //   console.log(item)\n      // });\n      tempMenuList.forEach(function (value, index, array) {\n        //code something\n        console.log(value.children.length);\n        that.menuList = value.children.filter(item => item.type === \"menu\");\n      });\n      console.log(tempMenuList[0].children);\n      //that.menuList=store.state.menuList;\n      //that.menuList=menuResult\n      // that.menuList.filter(\n      //   (item) => item.type=='menu'\n      // );\n      //matched = this.menuList.concat(matched);\n      // this.menuList = matched.filter(\n      //   (item) => item.meta && item.meta.title && item.meta.breadcrumb !== false\n      // );\n    },\n\n    //获取路径的面包屑，首页/其他页/其他页\n    getBreadcrumb() {\n      let matched = this.$route.matched.filter(item => item.meta && item.meta.title && item.path !== \"\");\n      //console.log(matched)\n      const first = matched[0];\n      if (!this.isHome(first)) {\n        matched = [{\n          path: \"/\",\n          name: \"home\",\n          meta: {\n            title: \"首页\"\n          }\n        }].concat(matched);\n      }\n      this.levelList = matched.filter(item => item.meta && item.meta.title !== false);\n      //console.log(matched)//匹配路由地址，用来显示路径面包屑\n      //console.log(this.levelList);//匹配路由地址，用来显示路径面包屑\n    },\n\n    //判断当前路由是否是首页，返回两者等于的结果true\n    isHome(route) {\n      const name = route && route.name;\n      if (!name) {\n        return false;\n      }\n      return name.trim().toLocaleLowerCase() === \"home\".toLocaleLowerCase(); //返回true\n    },\n\n    listGeekplusCategory() {\n      // listSubParentCategory().then(response => {\n      //   console.log(response);\n      //   this.dynamicsMenuRouter=response.data;\n      // }).catch(error => {\n      //   console.log(error);\n      // }).finally(() =>{\n      //   console.log(\"获取失败\");\n      // })\n      (0, _dynamicrouter.getChildrenPath)();\n    },\n    searchResult() {\n      if (this.keywords !== \"\") {\n        //this.$router.push(\"/search?keayword=\"+this.keywords);\n        this.$router.push({\n          path: \"/search\",\n          query: {\n            keyword: this.keywords\n          }\n        });\n      }\n      this.keywords = \"\";\n    },\n    deep(obj) {\n      let objName1 = JSON.stringify(obj);\n      let objName2 = JSON.parse(objName1);\n      return objName2;\n    }\n  }\n};\nexports.default = _default;","map":{"version":3,"names":["_index","_interopRequireDefault","require","_BackToTop","_mai","_geekplus","_dynamicrouter","_AppMain","_default","name","components","BackToTop","AppMain","data","theme1","visible","contentScrollTop","isBackTop","menuList","friendlyLinkList","dynamicsMenuRouter","levelList","transName","myBackToTopStyle","GCLogo","MKLogo","maiLogo","topNavBarFixed","navBarStyle","keywords","subParentCategoryList","webHeaderFooterInfo","computed","keyPath","$route","path","created","getMneuList","getBreadcrumb","displayWebFriendlyLink","getWebTitleNameFooterInfo","mounted","window","onscroll","st","document","documentElement","scrollTop","body","onresize","hheight","fullHeight","clientHeight","wwidth","fullWidth","clientWidth","windowHeight","windowWidth","watch","val","that","console","log","handler","oldVal","deep","methods","getPath","displayFriendlyLink","then","response","catch","error","msg","queryParams","id","getGpWebTitleInfo","backToTopBtn","top","timeTop","setInterval","clearInterval","afterBackToTop","num","handleOpen","handleClose","mouseOverIt","mouseOutIt","tempMenuList","Array","$router","options","routes","filter","item","type","forEach","value","index","array","children","length","matched","meta","title","first","isHome","concat","route","trim","toLocaleLowerCase","listGeekplusCategory","getChildrenPath","searchResult","push","query","keyword","obj","objName1","JSON","stringify","objName2","parse","exports","default"],"sources":["src/layout/index.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <!-- <nav>\n        <router-link to=\"/\">Home</router-link> |\n        <router-link to=\"/about\">About</router-link>\n      </nav>\n      <router-view/> -->\n    <header class=\"header hidden-xs\">\n      <div class=\"container\">\n        <div class=\"row\">\n          <div class=\"col-lg-12 col-md-12 col-sm-12 col-xs-12\">\n            <div class=\"logo\">\n              <img\n                v-lazy=\"GCLogo\"\n                class=\"top_banner_logo\"\n                @mouseover=\"mouseOverIt\"\n                @mouseout=\"mouseOutIt\"\n              />\n              <span class=\"logo-text navbar-collapse collapse animated rotateIn\"\n                >极客普拉斯</span\n              >\n            </div>\n            <div class=\"right-block\">\n              <div class=\"wow pulse bg-yellow\" data-wow-delay=\"0.1s\">\n                人生，\n              </div>\n              <div\n                class=\"wow rollIn bg-red\"\n                data-wow-iteration=\"1\"\n                data-wow-duration=\"0.5s\"\n              >\n                就像一盒巧克力，\n              </div>\n              <div class=\"wow bounceInRight bg-blue\">\n                你永远不知道下一块会是什么味道！\n              </div>\n              <div class=\"wow bounceInRight bg-blue\">---《阿甘正传》</div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </header>\n    <!-- <div class=\"gc-slide\">\n        <div class=\"gc_hand_top\" id=\"backToTop\">\n          <a href=\"javascript:void(0);\" class=\"gc_hand_top_btn\"\n            ><i class=\"gcfont\"></i><span>返回顶部</span></a\n          >\n        </div>\n      </div> -->\n    <nav :class=\"topNavBarFixed\" id=\"navigator_bar\">\n      <div class=\"container\">\n        <div class=\"navbar-header\">\n          <button\n            class=\"navbar-toggle pull-right\"\n            @click=\"$router.push('/chatgpt')\"\n          >\n            <span class=\"glyphicon glyphicon-road\" aria-hidden=\"true\"></span>\n          </button>\n          <button\n            class=\"navbar-toggle pull-right\"\n            data-toggle=\"collapse\"\n            data-target=\"#collapse_searche_div\"\n          >\n            <span class=\"glyphicon glyphicon-search\"></span>\n          </button>\n          <button\n            class=\"navbar-toggle pull-right\"\n            data-toggle=\"collapse\"\n            data-target=\"#navbar_collapse_div\"\n          >\n            <span class=\"icon-bar\"></span>\n            <span class=\"icon-bar\"></span>\n            <span class=\"icon-bar\"></span>\n          </button>\n          <router-link class=\"navbar-brand visible-xs\" to=\"/\">\n            <!-- <img v-lazy=\"GCLogo\" class=\"logo_img\" @onmouseover=\"mouseOverIt\"\n                @onmouseout=\"mouseOutIt\" style=\"width:20px;height:20px;\" /> -->\n            <span ref=\"brandText\">极客普拉斯</span>\n          </router-link>\n          <!-- <router-link class=\"navbar-left visible-xs\" href=\"https://www.geekplus.xyz/\">\n              <img alt=\"极客普拉斯\" id=\"navbar-brand-img\" v-lazy=\"GCLogo\" >极客普拉斯\n            </router-link> -->\n        </div>\n        <div class=\"collapse animated fadeInDown\" id=\"collapse_searche_div\">\n          <div class=\"search_bar_top\">\n            <!-- <form action=\"/searchResult\" class=\"input-group input-group-lg\">\n                <input type=\"text\" class=\"form-control\" placeholder=\"请输入您要搜索的内容...\">\n                <span class=\"input-group-btn\">\n                  <button class=\"btn btn-default\" type=\"submit\">\n                    <span class=\"glyphicon glyphicon-search\" aria-hidden=\"true\"></span>\n                  </button>\n                </span>\n              </form> -->\n            <form>\n              <input\n                type=\"text\"\n                class=\"form-control\"\n                placeholder=\"请输入您要搜索的内容...\"\n                name=\"keywords\"\n                v-model=\"keywords\"\n              />\n              <button type=\"button\">\n                <span\n                  class=\"glyphicon glyphicon-search\"\n                  @click=\"searchResult()\"\n                  aria-hidden=\"true\"\n                ></span>\n              </button>\n            </form>\n          </div>\n        </div>\n        <div class=\"navbar-collapse collapse\" id=\"navbar_collapse_div\">\n          <ul class=\"nav navbar-nav navbar-left navbar_ul\">\n            <!-- :class=\"isHome&&index===0?'menuactive':''\" -->\n            <li\n              :class=\"keyPath == item.path ? 'menuactive' : ''\"\n              v-for=\"(item, index) in menuList\"\n              :key=\"index\"\n            >\n              <router-link :to=\"item.path\">\n                <a href=\"javascript:void(0)\">{{ item.meta.title }}</a>\n              </router-link>\n\n              <!-- v-if=\"item.children.length===0\" <a v-if=\"item.children.length!==0\" href=\"javascript:void(0)\">{{ item.meta.title }}</a> -->\n              <div v-if=\"item.children.length !== 0\" class=\"itembox\">\n                <ul class=\"nav-pills nav-stacked\">\n                  <li\n                    :class=\"keyPath == subitem.path ? 'menuactive' : ''\"\n                    v-for=\"(subitem, index) in item.children\"\n                    :key=\"index\"\n                  >\n                    <router-link :to=\"subitem.path\">\n                      <a href=\"javascript:void(0)\">{{ subitem.meta.title }}</a>\n                    </router-link>\n                  </li>\n                </ul>\n              </div>\n            </li>\n            <!-- <li>\n                <a href=\"/blogArtices\">编程技术</a>\n              </li>\n              <li>\n                <a href=\"/newTalkList\">新闻杂谈</a>\n              </li>\n  \n              <li>\n                <a href=\"/resourceDownload\">资源文件</a>\n              </li>\n  \n              <li>\n                <a href=\"javascript:0;\">生活随笔</a>\n                <div class=\"itembox\">\n                  <ul>\n                    <li><a href=\"/thinkingLife\">格物生活</a></li>\n                    <li><a href=\"/personalEssay\">个人随笔</a></li>\n                  </ul>\n                </div>\n              </li>\n  \n              <li>\n                <a href=\"/leavemessage-board\">给我留言</a>\n              </li>\n              <li>\n                <a href=\"/about\">关于梦极客园</a>\n              </li> -->\n          </ul>\n          <ul class=\"nav navbar-nav navbar-right hidden-sm\">\n            <li>\n              <a href=\"https://maikeadmin.geekplus.xyz/chat\"\n                >ChatGPT智能助手<span class=\"badge\"></span\n              ></a>\n            </li>\n            <!-- <li class=\"dropdown\">\n                <a\n                  href=\"#\"\n                  class=\"dropdown-toggle\"\n                  data-toggle=\"dropdown\"\n                  role=\"button\"\n                  aria-haspopup=\"true\"\n                  aria-expanded=\"false\"\n                  >梦极客<span class=\"caret\"></span\n                ></a>\n                <ul class=\"dropdown dropdown-menu navbar_ul\">\n                  <li><a href=\"#\">个人中心</a></li>\n                  <li><a href=\"#\">我的收藏</a></li>\n                  <li><a href=\"#\">账号设置</a></li>\n                  <li role=\"separator\" class=\"divider\"></li>\n                  <li><a href=\"#\">退出</a></li>\n                </ul>\n              </li> -->\n          </ul>\n        </div>\n      </div>\n    </nav>\n    <back-to-top\n      class=\"hidden-xs hidden-sm\"\n      :transitionName=\"transName\"\n      :customStyle=\"myBackToTopStyle\"\n      :visibilityHeight=\"600\"\n      :backPosition=\"150\"\n    >\n    </back-to-top>\n\n    <!-- <wave-item></wave-item> -->\n\n    <div :style=\"navBarStyle\">\n      <div class=\"container\" v-if=\"getPath() !== '/'\">\n        <ol class=\"gp_breadcrumb\">\n          <li><a href=\"#\">Home</a></li>\n          <li><a href=\"#\">Library</a></li>\n          <li class=\"active\">Data</li>\n        </ol>\n      </div>\n      <!-- <router-view :key=\"key\" /> -->\n      <app-main />\n    </div>\n\n    <!-- <div class=\"gc-slide\" v-if=\"isBackTop\">\n        <div class=\"gc_hand_top\" id=\"backToTop\">\n          <a\n            href=\"javascript:void(0);\"\n            @click=\"backToTop\"\n            class=\"gc_hand_top_btn\"\n          >\n            <span class=\"glyphicon glyphicon-search\" aria-hidden=\"true\"></span>\n            <img\n              v-if=\"isBackTop\"\n              class=\"go-top\"\n              src=\"imgs/bloglogo.png\"\n              @click=\"backToTop\"\n            />\n            <i class=\"gcfont\"></i><span>返回顶部</span>\n          </a>\n        </div>\n      </div> -->\n    <nav\n      class=\"navbar navbar-default navbar-fixed-bottom visible-xs visible-sm\"\n    >\n      <div class=\"container\">\n        <div class=\"row\">\n          <div class=\"col-xs-3 col-sm-3 text-center\">\n            <!-- 行内跳转方式(同样可以传参)： -->\n            <div class=\"bg-secondary\" @click=\"$router.push('/')\">\n              <div class=\"\">\n                <span class=\"glyphicon glyphicon-home\"></span>\n              </div>\n              <div class=\"navbar-fixed-text-size\">\n                <small>主页</small>\n              </div>\n            </div>\n          </div>\n          <div class=\"col-xs-3 col-sm-3 text-center\">\n            <div class=\"bg-secondary\">\n              <div class=\"\">\n                <span class=\"glyphicon glyphicon-asterisk\"></span>\n              </div>\n              <div class=\"navbar-fixed-text-size\">\n                <small>待定</small>\n              </div>\n            </div>\n          </div>\n          <div class=\"col-xs-3 col-sm-3 text-center\">\n            <!-- @click=\"$router.push('/leaveMessage')\" -->\n            <div class=\"bg-secondary\" @click=\"$router.push('/leaveMessage')\">\n              <div class=\"\">\n                <span class=\"glyphicon glyphicon-comment\"></span>\n              </div>\n              <div class=\"navbar-fixed-text-size\">\n                <small>留言</small>\n              </div>\n            </div>\n          </div>\n          <div class=\"col-xs-3 col-sm-3 text-center\">\n            <div class=\"bg-secondary\" @click=\"backToTopBtn\">\n              <div class=\"\">\n                <span class=\"glyphicon glyphicon-menu-up\"></span>\n              </div>\n              <div class=\"navbar-fixed-text-size\">\n                <small>顶部</small>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </nav>\n    <div class=\"friendlink_container\">\n      <div class=\"container\">\n        <div class=\"row\">\n          <div class=\"col-md-12\">\n            <div class=\"friendlink_title\"><label>友情链接:</label></div>\n            <div class=\"friendlink_content\" id=\"friendlink_content\">\n              <a\n                class=\"friendlink_a\"\n                ref=\"friendlinkA\"\n                data-toggle=\"tooltip\"\n                :title=\"item.linkIntro\"\n                v-for=\"(item, index) in friendlyLinkList\"\n                :key=\"index\"\n                :href=\"item.linkUrl\"\n                >{{ item.linkName }}</a\n              >\n              <!-- <a class=\"friendlink_a