-box\n                    :messageReplyInfo=\"{\n                      id: item.id,\n                      repId: item.id,\n                      name: item.name,\n                    }\"\n                    v-if=\"item.id === replyBoxIndex\"\n                    v-on:getReplyMsg=\"getReplyMessage\"\n                    ref=\"replyMsgRef\"\n                  ></reply-message-box>\n                  <!-- </div> -->\n                </div>\n              </div>\n              <div v-if=\"item.children\" class=\"sub-comment-lw\">\n                <!-- <sub-reply-message  v-on:sendUserCommentStatus=\"getUserCommentStatus\" :replyMessage=\"item.children\"></sub-reply-message> -->\n                <div\n                  class=\"comment-main\"\n                  v-for=\"(subitem, index) in item.children\"\n                  :key=\"index\"\n                >\n                  <a class=\"user-logo\"><img v-lazy=\"subitem.userId=='sysUser:1'?GPLogo:UserLogo\" /></a>\n                  <div class=\"comment-content\">\n                    <div class=\"comment-info\">\n                      <a>{{ subitem.name }}</a>\n                      <span\n                        >&nbsp;回复：<a\n                          ><strong class=\"\">{{ subitem.replyName }}</strong></a\n                        ></span\n                      >\n                      <span class=\"comment_info_time\"\n                        >&nbsp;{{ subitem.createTime }}</span\n                      >\n                    </div>\n                    <div class=\"comment-text\" :style=\"'color:'+someColor()+';'\" v-if=\"checkHtml(subitem.content)\" v-html=\"subitem.content\"></div>\n                    <div class=\"comment-text\" :style=\"'color:'+someColor()+';'\" v-else v-text=\"subitem.content\"></div>\n                    <div class=\"comment-action\">\n                      <a\n                        href=\"javascript:void(0)\"\n                        @click=\"openReplyBox(subitem.id)\"\n                        >回复</a\n                      >\n                      &nbsp;\n                      <a\n                        v-if=\"subitem.id === replyBoxIndex\"\n                        href=\"javascript:void(0)\"\n                        @click=\"closeReplyBox\"\n                        >关闭</a\n                      >\n                    </div>\n                    <!-- <div v-if=\"isDisplayMsgBox\"> -->\n                    <reply-message-box\n                      :messageReplyInfo=\"{\n                        id: item.id,\n                        repId: subitem.id,\n                        name: subitem.name,\n                      }\"\n                      v-if=\"subitem.id === replyBoxIndex\"\n                      v-on:getReplyMsg=\"getReplyMessage\"\n                      ref=\"replyMsgRef\"\n                    ></reply-message-box>\n                    <!-- </div> -->\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n          <br />\n        </div>\n        <div class=\"pagenumber\">\n          <div class=\"container-fluid\">\n            <div class=\"row\">\n              <nav class=\"pagenum\" id=\"pagenum1\">\n                <span class=\"pagenum-btns\">\n                  <a\n                    class=\"pagenum-prev\"\n                    @click=\"goToLeaveMessagePage(leaveMessagePageNum - 1)\"\n                    >&laquo;</a\n                  >\n                  <!-- <a class=\"pagenum-num\">1</a>\n                  <span class=\"pagenum-break\">...</span>\n                  <a class=\"pagenum-num\">7</a>\n                  <a class=\"pagenum-num\">8</a>\n                  <a class=\"pagenum-active\">9</a>\n                  <a class=\"pagenum-num\">10</a>\n                  <a class=\"pagenum-num\">11</a>\n                  <span class=\"pagenum-break\">...</span>\n                  <a class=\"pagenum-num\">98</a> -->\n                  <span\n                    class=\"pagenum-break\"\n  